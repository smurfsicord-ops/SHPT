{%- comment -%}
  Section: diagnostic
  Quiz autonome — 5 étapes, résultats personnalisés
{%- endcomment -%}

<section class="diag" id="diagnostic">
  <div class="diag__container">

    <!-- INTRO -->
    <div class="diag__screen" id="screen-intro">
      <p class="diag__eyebrow">Outil gratuit</p>
      <h1 class="diag__title">Trouvez votre culotte <em>idéale</em></h1>
      <p class="diag__subtitle">5 questions · 2 minutes · Résultat personnalisé</p>
      <button class="diag__btn diag__btn--primary" onclick="diagStart()">Commencer le diagnostic →</button>
    </div>

    <!-- QUIZ -->
    <div class="diag__screen diag__screen--hidden" id="screen-quiz">

      <!-- Barre de progression -->
      <div class="diag__progress">
        <div class="diag__progress-bar" id="progress-bar"></div>
      </div>
      <p class="diag__step-label" id="step-label">Question 1 / 5</p>

      <!-- Questions -->
      <div class="diag__question" id="q1">
        <h2 class="diag__q-title">Quel est votre usage principal ?</h2>
        <div class="diag__options">
          <button class="diag__option" onclick="diagAnswer('q1','sport')">🏃 Sport & activité physique</button>
          <button class="diag__option" onclick="diagAnswer('q1','daily')">💼 Quotidien & travail</button>
          <button class="diag__option" onclick="diagAnswer('q1','night')">🌙 Protection nocturne</button>
          <button class="diag__option" onclick="diagAnswer('q1','travel')">✈️ Voyages & sorties</button>
        </div>
      </div>

      <div class="diag__question diag__question--hidden" id="q2">
        <h2 class="diag__q-title">Quelle est votre priorité absolue ?</h2>
        <div class="diag__options">
          <button class="diag__option" onclick="diagAnswer('q2','absorption')">💧 Absorption maximale</button>
          <button class="diag__option" onclick="diagAnswer('q2','discretion')">👗 Discrétion sous les vêtements</button>
          <button class="diag__option" onclick="diagAnswer('q2','comfort')">🌸 Confort et douceur</button>
          <button class="diag__option" onclick="diagAnswer('q2','style')">✨ Style et élégance</button>
        </div>
      </div>

      <div class="diag__question diag__question--hidden" id="q3">
        <h2 class="diag__q-title">Comment décrivez-vous votre flux ?</h2>
        <div class="diag__options">
          <button class="diag__option" onclick="diagAnswer('q3','light')">🟢 Léger — quelques gouttes</button>
          <button class="diag__option" onclick="diagAnswer('q3','moderate')">🟡 Modéré — fuites régulières</button>
          <button class="diag__option" onclick="diagAnswer('q3','heavy')">🔴 Abondant — protection totale</button>
          <button class="diag__option" onclick="diagAnswer('q3','variable')">🔄 Variable selon les jours</button>
        </div>
      </div>

      <div class="diag__question diag__question--hidden" id="q4">
        <h2 class="diag__q-title">Quelle matière préférez-vous ?</h2>
        <div class="diag__options">
          <button class="diag__option" onclick="diagAnswer('q4','cotton')">🌿 Coton naturel</button>
          <button class="diag__option" onclick="diagAnswer('q4','microfiber')">⚡ Microfibre légère</button>
          <button class="diag__option" onclick="diagAnswer('q4','bamboo')">🎋 Bambou doux</button>
          <button class="diag__option" onclick="diagAnswer('q4','technical')">🔬 Technique haute performance</button>
        </div>
      </div>

      <div class="diag__question diag__question--hidden" id="q5">
        <h2 class="diag__q-title">À quelle fréquence en avez-vous besoin ?</h2>
        <div class="diag__options">
          <button class="diag__option" onclick="diagAnswer('q5','daily')">📅 Tous les jours</button>
          <button class="diag__option" onclick="diagAnswer('q5','weekly')">📆 Quelques fois par semaine</button>
          <button class="diag__option" onclick="diagAnswer('q5','occasional')">🗓️ Occasionnellement</button>
          <button class="diag__option" onclick="diagAnswer('q5','periodic')">🔁 Seulement les règles</button>
        </div>
      </div>

    </div>

    <!-- RÉSULTAT -->
    <div class="diag__screen diag__screen--hidden" id="screen-result">
      <div class="diag__result" id="result-content"></div>
      <button class="diag__btn diag__btn--ghost" onclick="diagRestart()">↩ Recommencer le diagnostic</button>
    </div>

  </div>
</section>

<style>
.diag {
  min-height: 80vh;
  display: flex;
  align-items: center;
  background: #f7f6f2;
  padding: 4rem 1.5rem;
  font-family: inherit;
}
.diag__container {
  max-width: 640px;
  margin: 0 auto;
  width: 100%;
}
.diag__screen {
  text-align: center;
}
.diag__screen--hidden {
  display: none;
}
.diag__eyebrow {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: #01696f;
  margin-bottom: 1rem;
}
.diag__title {
  font-size: clamp(2rem, 1rem + 3vw, 3.2rem);
  font-weight: 800;
  line-height: 1.1;
  color: #28251d;
  margin-bottom: 0.75rem;
}
.diag__title em {
  font-style: normal;
  color: #01696f;
}
.diag__subtitle {
  font-size: 1rem;
  color: #7a7974;
  margin-bottom: 2.5rem;
}
.diag__btn {
  display: inline-block;
  padding: 14px 32px;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  border: none;
  transition: background 180ms ease, transform 120ms ease;
  text-decoration: none;
}
.diag__btn--primary {
  background: #01696f;
  color: #fff;
}
.diag__btn--primary:hover {
  background: #0c4e54;
  transform: translateY(-1px);
}
.diag__btn--ghost {
  background: transparent;
  color: #28251d;
  border: 1.5px solid #d4d1ca;
  margin-top: 1.5rem;
}
.diag__btn--ghost:hover {
  border-color: #01696f;
  color: #01696f;
}
.diag__progress {
  height: 6px;
  background: #e6e4df;
  border-radius: 999px;
  overflow: hidden;
  margin-bottom: 1rem;
}
.diag__progress-bar {
  height: 100%;
  background: #01696f;
  border-radius: 999px;
  width: 20%;
  transition: width 400ms cubic-bezier(0.16,1,0.3,1);
}
.diag__step-label {
  font-size: 0.82rem;
  color: #7a7974;
  font-weight: 600;
  margin-bottom: 2rem;
  letter-spacing: .05em;
}
.diag__q-title {
  font-size: clamp(1.3rem, 1rem + 1.2vw, 1.8rem);
  font-weight: 700;
  color: #28251d;
  margin-bottom: 1.75rem;
  line-height: 1.25;
}
.diag__options {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.diag__option {
  width: 100%;
  padding: 16px 20px;
  background: #fff;
  border: 1.5px solid #d4d1ca;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 500;
  color: #28251d;
  text-align: left;
  cursor: pointer;
  transition: border-color 180ms ease, background 180ms ease, transform 120ms ease;
}
.diag__option:hover {
  border-color: #01696f;
  background: #f0f7f7;
  transform: translateX(4px);
}
.diag__option.selected {
  border-color: #01696f;
  background: #e0f0f0;
  color: #01696f;
  font-weight: 700;
}
.diag__question--hidden {
  display: none;
}
/* Résultat */
.diag__result {
  background: #fff;
  border: 1.5px solid #d4d1ca;
  border-radius: 16px;
  padding: 2.5rem 2rem;
  margin-bottom: 1rem;
  text-align: left;
}
.diag__result-badge {
  display: inline-block;
  background: #e0f0f0;
  color: #01696f;
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  border-radius: 999px;
  padding: 4px 14px;
  margin-bottom: 1.25rem;
}
.diag__result-emoji {
  font-size: 3rem;
  display: block;
  margin-bottom: 0.75rem;
}
.diag__result-name {
  font-size: 1.6rem;
  font-weight: 800;
  color: #28251d;
  margin-bottom: 0.5rem;
  line-height: 1.2;
}
.diag__result-desc {
  font-size: 0.97rem;
  color: #7a7974;
  line-height: 1.65;
  margin-bottom: 1.75rem;
}
.diag__result-specs {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.75rem;
}
.diag__result-spec {
  background: #f7f6f2;
  border: 1px solid #e6e4df;
  border-radius: 999px;
  padding: 5px 14px;
  font-size: 0.82rem;
  font-weight: 600;
  color: #28251d;
}
.diag__result-cta {
  display: inline-block;
  background: #01696f;
  color: #fff;
  padding: 14px 28px;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 700;
  text-decoration: none;
  transition: background 180ms ease;
}
.diag__result-cta:hover {
  background: #0c4e54;
}
@media (max-width: 480px) {
  .diag__result {
    padding: 1.75rem 1.25rem;
  }
}
</style>

<script>
var diagAnswers = {};
var diagCurrentQ = 1;

var diagProfiles = {
  sport: {
    emoji: '🏃',
    badge: 'Votre profil',
    name: 'Sport Haute Performance',
    desc: 'Vous avez besoin d\'une protection qui suit chaque mouvement sans compromettre la liberté. Nos culottes techniques offrent une absorption fiable et un maintien optimal pendant l\'effort.',
    specs: ['Absorption renforcée', 'Matière technique', 'Maintien actif', 'Séchage rapide'],
    cta_label: 'Voir la collection Sport',
    cta_url: '/collections/all'
  },
  night: {
    emoji: '🌙',
    badge: 'Votre profil',
    name: 'Protection Nuit Complète',
    desc: 'Pour des nuits sereines, vous avez besoin d\'une protection maximale qui s\'adapte à tous vos mouvements. Nos modèles nuit offrent jusqu\'à 300ml d\'absorption pour un sommeil sans souci.',
    specs: ['Jusqu\'à 300ml', 'Coupe nuit évasée', 'Ultra douce', 'Toute la nuit'],
    cta_label: 'Voir les modèles nuit',
    cta_url: '/collections/all'
  },
  discretion: {
    emoji: '💼',
    badge: 'Votre profil',
    name: 'Discrétion Quotidienne',
    desc: 'Au bureau comme en soirée, vous voulez une protection invisible. Nos modèles fin profil s\'effacent sous tous les vêtements tout en restant parfaitement efficaces au quotidien.',
    specs: ['Profil ultra-fin', 'Invisible sous vêtements', 'Comfort toute la journée', 'Élégant'],
    cta_label: 'Voir les modèles discrets',
    cta_url: '/collections/all'
  },
  eco: {
    emoji: '🌿',
    badge: 'Votre profil',
    name: 'Éco & Bien-être',
    desc: 'Vous privilégiez les matières naturelles et durables. Nos culottes en bambou ou coton bio allient douceur, respect de la peau et efficacité pour un confort responsable.',
    specs: ['Bambou ou coton bio', 'Hypoallergénique', 'Durable', 'Peau sensible'],
    cta_label: 'Voir la collection Naturel',
    cta_url: '/collections/all'
  },
  discovery: {
    emoji: '🎁',
    badge: 'Votre profil',
    name: 'Pack Découverte Idéal',
    desc: 'Vous débutez avec les culottes absorbantes. Notre Pack Découverte inclut 2 modèles complémentaires pour tester différents niveaux de protection et trouver votre préféré.',
    specs: ['2 modèles inclus', 'Niveaux variés', '-10% économisé', 'Satisfait ou remboursé'],
    cta_label: 'Voir le Pack Découverte',
    cta_url: '/collections/all'
  }
};

function diagStart() {
  document.getElementById('screen-intro').classList.add('diag__screen--hidden');
  document.getElementById('screen-quiz').classList.remove('diag__screen--hidden');
  diagCurrentQ = 1;
  diagAnswers = {};
  diagShowQ(1);
}

function diagShowQ(n) {
  for (var i = 1; i <= 5; i++) {
    var el = document.getElementById('q' + i);
    if (el) el.classList.add('diag__question--hidden');
  }
  var current = document.getElementById('q' + n);
  if (current) current.classList.remove('diag__question--hidden');
  document.getElementById('step-label').textContent = 'Question ' + n + ' / 5';
  document.getElementById('progress-bar').style.width = (n * 20) + '%';
}

function diagAnswer(qId, value) {
  diagAnswers[qId] = value;
  var opts = document.querySelectorAll('#' + qId + ' .diag__option');
  opts.forEach(function(o) { o.classList.remove('selected'); });
  event.currentTarget.classList.add('selected');
  setTimeout(function() {
    var next = diagCurrentQ + 1;
    if (next <= 5) {
      diagCurrentQ = next;
      diagShowQ(next);
    } else {
      diagShowResult();
    }
  }, 350);
}

function diagShowResult() {
  var profile = diagComputeProfile();
  var p = diagProfiles[profile];
  document.getElementById('result-content').innerHTML =
    '<span class="diag__result-emoji">' + p.emoji + '</span>' +
    '<span class="diag__result-badge">' + p.badge + '</span>' +
    '<h2 class="diag__result-name">' + p.name + '</h2>' +
    '<p class="diag__result-desc">' + p.desc + '</p>' +
    '<div class="diag__result-specs">' +
      p.specs.map(function(s){ return '<span class="diag__result-spec">' + s + '</span>'; }).join('') +
    '</div>' +
    '<a href="' + p.cta_url + '" class="diag__result-cta">' + p.cta_label + '</a>';
  document.getElementById('screen-quiz').classList.add('diag__screen--hidden');
  document.getElementById('screen-result').classList.remove('diag__screen--hidden');
  document.getElementById('progress-bar').style.width = '100%';
}

function diagComputeProfile() {
  var usage = diagAnswers['q1'];
  var priority = diagAnswers['q2'];
  var flux = diagAnswers['q3'];
  var material = diagAnswers['q4'];
  var freq = diagAnswers['q5'];
  if (usage === 'sport') return 'sport';
  if (usage === 'night' || flux === 'heavy') return 'night';
  if (priority === 'discretion') return 'discretion';
  if (material === 'bamboo' || material === 'cotton') return 'eco';
  if (freq === 'occasional' || freq === 'periodic') return 'discovery';
  return 'discretion';
}

function diagRestart() {
  diagAnswers = {};
  diagCurrentQ = 1;
  document.getElementById('screen-result').classList.add('diag__screen--hidden');
  document.getElementById('screen-intro').classList.remove('diag__screen--hidden');
  document.getElementById('progress-bar').style.width = '20%';
}
</script>

{% schema %}
{
  "name": "Diagnostic Quiz",
  "tag": "section",
  "class": "section-diagnostic",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Trouvez votre culotte idéale" }
  ],
  "presets": [{ "name": "Diagnostic Quiz" }]
}
{% endschema %}
