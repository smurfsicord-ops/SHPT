{%- comment -%}
  Section: cta-banner
  Description: Bandeau CTA final — conversion Octipa
  Schema: eyebrow, title, description, btn1, btn2
{%- endcomment -%}

{%- liquid
  assign title_parts = section.settings.title | split: '**'
-%}

<section class="cta-banner">
  <div class="container">
    <div class="cta-banner__inner">
      <div class="cta-banner__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="cta-banner__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="cta-banner__title">
          {%- for part in title_parts -%}
            {%- if forloop.index0 == 1 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
          {%- endfor -%}
        </h2>
        {%- if section.settings.description != blank -%}
          <p class="cta-banner__desc">{{ section.settings.description }}</p>
        {%- endif -%}
        <div class="cta-banner__actions">
          {%- if section.settings.btn1_label != blank -%}
            <a href="{{ section.settings.btn1_url | default: '/collections/all' }}" class="btn btn--white btn--lg">{{ section.settings.btn1_label }}</a>
          {%- endif -%}
          {%- if section.settings.btn2_label != blank -%}
            <a href="{{ section.settings.btn2_url | default: '/pages/diagnostic' }}" class="btn btn--outline-white btn--lg">{{ section.settings.btn2_label }}</a>
          {%- endif -%}
        </div>
      </div>
      <div class="cta-banner__badges">
        <div class="trust-badge">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          <span>Emballage discret</span>
        </div>
        <div class="trust-badge">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
          <span>Livraison offerte dès 49€</span>
        </div>
        <div class="trust-badge">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          <span>Satisfait ou remboursé 30j</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.cta-banner {
  background: var(--color-primary, #5b8a8f);
  padding-block: clamp(3rem, 6vw, 5rem);
}

.cta-banner__inner {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
  align-items: center;
  text-align: center;
}

@media (min-width: 768px) {
  .cta-banner__inner { flex-direction: row; justify-content: space-between; text-align: left; }
}

.cta-banner__content { max-width: 560px; }

.cta-banner__eyebrow {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: rgba(255,255,255,.7);
  margin-bottom: 0.75rem;
}

.cta-banner__title {
  font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.5rem);
  font-weight: 700;
  line-height: 1.15;
  color: #fff;
  margin-bottom: 1rem;
}

.cta-banner__title em { font-style: normal; opacity: .85; }

.cta-banner__desc {
  font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1.05rem);
  color: rgba(255,255,255,.8);
  line-height: 1.7;
  margin-bottom: 1.75rem;
  max-width: 46ch;
}

.cta-banner__actions { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
@media (min-width: 768px) { .cta-banner__actions { justify-content: flex-start; } }

.btn--white { background: #fff; color: var(--color-primary, #5b8a8f); }
.btn--white:hover { background: #f0f0f0; transform: translateY(-1px); }
.btn--outline-white { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,.6); }
.btn--outline-white:hover { border-color: #fff; background: rgba(255,255,255,.1); }

.cta-banner__badges {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  flex-shrink: 0;
}

.trust-badge {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  color: rgba(255,255,255,.9);
  font-size: 0.9rem;
  font-weight: 500;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Bandeau CTA",
  "tag": "section",
  "class": "section-cta-banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Accroche", "default": "Prête à vous libérer ?" },
    { "type": "textarea", "id": "title", "label": "Titre (**italic**)", "default": "Commencez votre **routine confort**" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Rejoignez des milliers de femmes qui ont retrouvé confiance et liberté au quotidien." },
    { "type": "text", "id": "btn1_label", "label": "Bouton principal", "default": "Découvrir la boutique" },
    { "type": "url", "id": "btn1_url", "label": "Lien bouton principal" },
    { "type": "text", "id": "btn2_label", "label": "Bouton secondaire", "default": "Faire le diagnostic" },
    { "type": "url", "id": "btn2_url", "label": "Lien bouton secondaire" }
  ],
  "presets": [{ "name": "Bandeau CTA" }]
}
{% endschema %}
