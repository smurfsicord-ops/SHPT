{%- comment -%}
  Section: diagnostic-quiz-page
  Description: Quiz interactif de diagnostic culotte menstruelle
{%- endcomment -%}

<section class="dqp">
  <div class="dqp__inner">

    {%- comment -%} INTRO {%- endcomment -%}
    <div class="dqp__intro" id="dqp-intro">
      <p class="dqp__eyebrow">Diagnostic gratuit</p>
      <h1 class="dqp__title">Trouvez la culotte <em>faite pour vous</em></h1>
      <p class="dqp__subtitle">5 questions · 2 minutes · Recommandation personnalisée</p>
      <button class="dqp__btn dqp__btn--primary" id="dqp-start">Commencer →</button>
    </div>

    {%- comment -%} QUIZ {%- endcomment -%}
    <div class="dqp__quiz" id="dqp-quiz" style="display:none">
      <div class="dqp__progress">
        <p class="dqp__step" id="dqp-step">Question 1 / 5</p>
        <div class="dqp__bar-track"><div class="dqp__bar-fill" id="dqp-bar"></div></div>
      </div>
      <h2 class="dqp__question" id="dqp-question"></h2>
      <div class="dqp__options" id="dqp-options"></div>
    </div>

    {%- comment -%} RÉSULTAT {%- endcomment -%}
    <div class="dqp__result" id="dqp-result" style="display:none">
      <p class="dqp__eyebrow">Votre profil Octipa</p>
      <h2 class="dqp__result-title" id="dqp-rtitle"></h2>
      <p class="dqp__result-desc" id="dqp-rdesc"></p>
      <div class="dqp__tags" id="dqp-rtags"></div>
      <div class="dqp__result-actions">
        <a href="/collections/all" class="dqp__btn dqp__btn--primary">Voir la recommandation →</a>
        <button class="dqp__btn dqp__btn--ghost" id="dqp-restart">Recommencer</button>
      </div>
    </div>

  </div>
</section>

{% stylesheet %}
.dqp {
  background: #f8f4ef;
  min-height: 80vh;
  display: flex;
  align-items: center;
  padding: 60px 20px;
}
.dqp__inner {
  max-width: 680px;
  margin: 0 auto;
  width: 100%;
  background: #fff;
  border-radius: 24px;
  padding: clamp(28px, 5vw, 52px);
  box-shadow: 0 8px 40px rgba(0,0,0,.07);
}
.dqp__eyebrow {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .14em;
  color: #a06f5d;
  margin: 0 0 14px;
}
.dqp__title {
  font-size: clamp(28px, 5vw, 46px);
  font-weight: 800;
  color: #1e110a;
  line-height: 1.1;
  margin: 0 0 14px;
}
.dqp__title em {
  color: #b7806e;
  font-style: normal;
}
.dqp__subtitle {
  color: #6e5d55;
  font-size: 16px;
  margin: 0 0 28px;
}
.dqp__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 26px;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  border: none;
  text-decoration: none;
  transition: opacity .2s, transform .15s;
}
.dqp__btn:hover { opacity: .88; transform: translateY(-1px); }
.dqp__btn--primary { background: #1e110a; color: #fff; }
.dqp__btn--ghost { background: #fff; border: 1.5px solid #d9c9bf; color: #1e110a; }
.dqp__progress { margin-bottom: 28px; }
.dqp__step {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: #8c776d;
  margin: 0 0 10px;
}
.dqp__bar-track {
  height: 6px;
  background: #f1e8e0;
  border-radius: 99px;
  overflow: hidden;
}
.dqp__bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #b7806e, #1e110a);
  border-radius: 99px;
  transition: width .4s cubic-bezier(.4,0,.2,1);
  width: 20%;
}
.dqp__question {
  font-size: clamp(20px, 3vw, 30px);
  font-weight: 700;
  color: #1e110a;
  margin: 0 0 22px;
  line-height: 1.25;
}
.dqp__options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
@media (max-width: 480px) { .dqp__options { grid-template-columns: 1fr; } }
.dqp__option {
  background: #fdfaf7;
  border: 1.5px solid #eadfd4;
  border-radius: 14px;
  padding: 18px 16px;
  font-size: 14px;
  font-weight: 600;
  color: #34231c;
  text-align: left;
  cursor: pointer;
  transition: border-color .2s, background .2s, transform .15s;
}
.dqp__option:hover {
  border-color: #b7806e;
  background: #fdf6f2;
  transform: translateY(-2px);
}
.dqp__result-title {
  font-size: clamp(22px, 3vw, 36px);
  font-weight: 800;
  color: #1e110a;
  margin: 0 0 12px;
}
.dqp__result-desc {
  font-size: 15px;
  color: #6e5d55;
  line-height: 1.75;
  margin: 0 0 20px;
  max-width: 56ch;
}
.dqp__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 28px;
}
.dqp__tag {
  padding: 7px 14px;
  border-radius: 99px;
  background: #fcf6f2;
  border: 1px solid #eadfd4;
  font-size: 13px;
  font-weight: 700;
  color: #5e463b;
}
.dqp__result-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
{% endstylesheet %}

{% javascript %}
(function(){
  var qs=[
    {k:'u',q:'Dans quelle situation porterez-vous votre culotte ?',o:[['Au quotidien','daily'],['La nuit','night'],['Pendant le sport','sport'],['Un peu tout','mixed']]},
    {k:'f',q:'Quel niveau de flux recherchez-vous ?',o:[['Léger','light'],['Modéré','medium'],['Élevé','heavy'],['Variable','variable']]},
    {k:'p',q:'Quelle qualité est la plus importante ?',o:[['Le confort','comfort'],['La discrétion','discreet'],['La sécurité','security'],['Le style','style']]},
    {k:'m',q:'Quelle matière préférez-vous ?',o:[['Coton doux','cotton'],['Technique','technical'],['Très souple','soft'],['Pas de préférence','any']]},
    {k:'c',q:'Comment souhaitez-vous commencer ?',o:[['Un seul modèle','single'],['Un pack','pack'],['La meilleure option','best'],['Comparer','compare']]}
  ];
  var ps={
    night:{t:'Protection Nuit & Flux Intense',d:'Absorption maximale, coupe enveloppante, tient toute la nuit sans fuite.',tags:['Jusqu\'à 300ml','Coupe nuit','Ultra sécurisée','Bambou doux']},
    sport:{t:'Modèle Sport & Activité',d:'Respirante, maintien parfait, absorption fiable pendant l\'effort.',tags:['Matière technique','Respirante','Maintien actif','Flux modéré']},
    elegant:{t:'Modèle Discret & Élégant',d:'Fine, invisible sous vos vêtements, stylée pour toutes les occasions.',tags:['Ultra-fine','Invisible','Stylée','Quotidien']},
    pack:{t:'Pack Découverte Recommandé',d:'2 à 4 modèles complémentaires pour trouver votre favori au meilleur prix.',tags:['2-4 modèles','Économique','-15%','Satisfait ou remboursé']},
    comfort:{t:'Modèle Confort Quotidien',d:'Doux, rassurant, polyvalent. Le plus plébiscité pour un usage régulier.',tags:['Confort longue durée','Quotidien','Flux équilibré','Discrète']}
  };
  var step=0,ans={};

  function calc(){
    if(ans.u==='night'||ans.f==='heavy') return 'night';
    if(ans.u==='sport'||ans.m==='technical') return 'sport';
    if(ans.c==='pack'||ans.c==='compare') return 'pack';
    if(ans.p==='style'||ans.p==='discreet') return 'elegant';
    return 'comfort';
  }

  function showQ(){
    var q=qs[step];
    document.getElementById('dqp-step').textContent='Question '+(step+1)+' / 5';
    document.getElementById('dqp-bar').style.width=((step+1)/5*100)+'%';
    document.getElementById('dqp-question').textContent=q.q;
    var html='';
    q.o.forEach(function(o){
      html+='<button class="dqp__option" data-k="'+q.k+'" data-v="'+o[1]+'">'+o[0]+'</button>';
    });
    var el=document.getElementById('dqp-options');
    el.innerHTML=html;
    el.querySelectorAll('.dqp__option').forEach(function(btn){
      btn.addEventListener('click',function(){
        ans[this.dataset.k]=this.dataset.v;
        step++;
        if(step>=5){showResult();}else{showQ();}
      });
    });
  }

  function showResult(){
    document.getElementById('dqp-quiz').style.display='none';
    var p=ps[calc()];
    document.getElementById('dqp-rtitle').textContent=p.t;
    document.getElementById('dqp-rdesc').textContent=p.d;
    var tags=p.tags.map(function(t){return'<span class="dqp__tag">'+t+'</span>';}).join('');
    document.getElementById('dqp-rtags').innerHTML=tags;
    document.getElementById('dqp-result').style.display='block';
  }

  document.getElementById('dqp-start').addEventListener('click',function(){
    document.getElementById('dqp-intro').style.display='none';
    document.getElementById('dqp-quiz').style.display='block';
    step=0; ans={};
    showQ();
  });

  document.getElementById('dqp-restart').addEventListener('click',function(){
    document.getElementById('dqp-result').style.display='none';
    document.getElementById('dqp-intro').style.display='block';
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Quiz Diagnostic",
  "settings": []
}
{% endschema %}
