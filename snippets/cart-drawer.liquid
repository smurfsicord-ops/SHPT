{%- comment -%}
  Snippet: cart-drawer
  Description: Panier latéral AJAX Octipa — position fixed droite, overlay, JS AJAX
{%- endcomment -%}

<div id="CartOverlay" class="cart-overlay" aria-hidden="true"></div>

<div id="CartPanel" class="cart-panel" role="dialog" aria-modal="true" aria-label="Panier" aria-hidden="true">
  <div class="cart-panel__header">
    <span class="cart-panel__title">Mon Panier</span>
    <button id="CartPanelClose" class="cart-panel__close" aria-label="Fermer le panier">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="cart-panel__body" id="CartPanelBody">
    <div class="cart-empty-msg" id="CartEmpty" style="display:none">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
      <p>Votre panier est vide</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Voir nos produits</a>
    </div>
    <div id="CartItems" class="cart-items"></div>
  </div>

  <div class="cart-panel__footer" id="CartPanelFooter" style="display:none">
    <div class="cart-total-row">
      <span>Total</span>
      <span class="cart-total-price" id="CartTotalPrice"></span>
    </div>
    <p class="cart-note">&#10003; Livraison offerte dès 49€</p>
    <a href="/checkout" class="btn btn--primary btn--full">Commander →</a>
    <a href="{{ routes.cart_url }}" class="btn btn--outline btn--full">Voir le panier complet</a>
  </div>
</div>

<style>
/* ============================================================
   CART DRAWER — Octipa
   ============================================================ */

.cart-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 999;
  backdrop-filter: blur(2px);
  opacity: 0;
  transition: opacity 300ms ease;
}

.cart-overlay.is-visible {
  display: block;
  opacity: 1;
}

.cart-panel {
  position: fixed;
  top: 0;
  right: 0;
  width: min(420px, 100vw);
  height: 100dvh;
  background: #fff;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  box-shadow: -4px 0 32px rgba(0,0,0,.12);
  transform: translateX(100%);
  transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
  visibility: hidden;
}

.cart-panel.is-open {
  transform: translateX(0);
  visibility: visible;
}

/* HEADER */
.cart-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px;
  border-bottom: 1px solid #e5e5e5;
  flex-shrink: 0;
}

.cart-panel__title {
  font-size: 1.1rem;
  font-weight: 700;
  color: #28251d;
  letter-spacing: -.01em;
}

.cart-panel__close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #f3f0ec;
  border: none;
  cursor: pointer;
  color: #28251d;
  transition: background 180ms ease;
}

.cart-panel__close:hover { background: #e8e4de; }

/* BODY */
.cart-panel__body {
  flex: 1;
  overflow-y: auto;
  padding: 16px 24px;
  overscroll-behavior: contain;
}

/* EMPTY */
.cart-empty-msg {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  padding: 60px 0;
  text-align: center;
  color: #7a7974;
}

.cart-empty-msg p {
  font-size: 1rem;
  color: #7a7974;
  max-width: 22ch;
}

/* ITEMS */
.cart-item {
  display: grid;
  grid-template-columns: 80px 1fr auto;
  gap: 14px;
  align-items: start;
  padding: 16px 0;
  border-bottom: 1px solid #f0ede8;
}

.cart-item img {
  width: 80px;
  height: 100px;
  object-fit: cover;
  border-radius: 8px;
  background: #f3f0ec;
}

.cart-item__details {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.cart-item__name {
  font-size: 0.92rem;
  font-weight: 600;
  color: #28251d;
  line-height: 1.35;
}

.cart-item__variant {
  font-size: 0.8rem;
  color: #7a7974;
}

.cart-item__price {
  font-size: 0.95rem;
  font-weight: 700;
  color: #28251d;
  margin-top: 4px;
}

.cart-item__qty {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
}

.cart-item__qty-btn {
  width: 28px;
  height: 28px;
  border-radius: 6px;
  border: 1px solid #ddd;
  background: #f7f6f2;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 150ms ease;
}

.cart-item__qty-btn:hover { background: #e8e4de; }

.cart-item__qty-count {
  font-size: 0.9rem;
  font-weight: 600;
  min-width: 18px;
  text-align: center;
}

.cart-item__remove {
  background: none;
  border: none;
  cursor: pointer;
  color: #b0aca6;
  font-size: 1.3rem;
  line-height: 1;
  padding: 2px 4px;
  transition: color 150ms ease;
  align-self: start;
  margin-top: 2px;
}

.cart-item__remove:hover { color: #e63946; }

/* FOOTER */
.cart-panel__footer {
  padding: 20px 24px 28px;
  border-top: 1px solid #e5e5e5;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cart-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 1rem;
  font-weight: 700;
  color: #28251d;
}

.cart-note {
  font-size: 0.8rem;
  color: #437a22;
  font-weight: 600;
  text-align: center;
  margin: 0;
  max-width: 100%;
}

.btn--full { width: 100%; text-align: center; }

.btn--outline {
  background: transparent;
  border: 1px solid #d4d1ca;
  color: #28251d;
  padding: 10px 16px;
  border-radius: 8px;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 180ms ease;
  text-decoration: none;
  display: block;
}

.btn--outline:hover { background: #f3f0ec; }

/* SPINNER */
@keyframes cart-spin { to { transform: rotate(360deg); } }
.cart-spinner {
  width: 20px; height: 20px;
  border: 2px solid #e5e5e5;
  border-top-color: #01696f;
  border-radius: 50%;
  animation: cart-spin .7s linear infinite;
  margin: 40px auto;
  display: block;
}
</style>

<script>
(function() {
  const panel   = document.getElementById('CartPanel');
  const overlay = document.getElementById('CartOverlay');
  const closeBtn = document.getElementById('CartPanelClose');
  const bodyEl  = document.getElementById('CartPanelBody');
  const itemsEl = document.getElementById('CartItems');
  const emptyEl = document.getElementById('CartEmpty');
  const footerEl = document.getElementById('CartPanelFooter');
  const totalEl  = document.getElementById('CartTotalPrice');

  if (!panel) return;

  /* ---- OPEN / CLOSE ---- */
  function openCart() {
    panel.classList.add('is-open');
    panel.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-visible');
    document.body.style.overflow = 'hidden';
    fetchCart();
  }

  function closeCart() {
    panel.classList.remove('is-open');
    panel.setAttribute('aria-hidden', 'true');
    overlay.classList.remove('is-visible');
    document.body.style.overflow = '';
  }

  closeBtn.addEventListener('click', closeCart);
  overlay.addEventListener('click', closeCart);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeCart(); });

  /* ---- OPEN ON CART ICON CLICK ---- */
  document.querySelectorAll('[data-cart-open], .header__cart, .cart-icon-bubble').forEach(el => {
    el.addEventListener('click', e => { e.preventDefault(); openCart(); });
  });

  /* ---- OPEN AFTER QUICK ADD ---- */
  document.addEventListener('cart:add', () => openCart());

  /* ---- FETCH CART ---- */
  function fetchCart() {
    itemsEl.innerHTML = '<span class="cart-spinner"></span>';
    emptyEl.style.display = 'none';
    footerEl.style.display = 'none';

    fetch('/cart.js')
      .then(r => r.json())
      .then(cart => renderCart(cart))
      .catch(() => { itemsEl.innerHTML = '<p style="text-align:center;color:#7a7974;padding:20px">Erreur de chargement.</p>'; });
  }

  /* ---- RENDER ---- */
  function renderCart(cart) {
    itemsEl.innerHTML = '';

    if (cart.item_count === 0) {
      emptyEl.style.display = 'flex';
      footerEl.style.display = 'none';
      return;
    }

    emptyEl.style.display = 'none';
    footerEl.style.display = 'flex';
    totalEl.textContent = formatMoney(cart.total_price);

    cart.items.forEach(item => {
      const div = document.createElement('div');
      div.className = 'cart-item';
      div.dataset.key = item.key;
      div.innerHTML = `
        <img src="${item.image ? item.image.replace(/\.jpg/, '_160x200.jpg') : ''}" alt="${escHtml(item.title)}" width="80" height="100" loading="lazy">
        <div class="cart-item__details">
          <div class="cart-item__name">${escHtml(item.product_title)}</div>
          ${item.variant_title && item.variant_title !== 'Default Title' ? `<div class="cart-item__variant">${escHtml(item.variant_title)}</div>` : ''}
          <div class="cart-item__price">${formatMoney(item.final_line_price)}</div>
          <div class="cart-item__qty">
            <button class="cart-item__qty-btn" data-qty-change="-1" data-key="${item.key}" data-qty="${item.quantity}" aria-label="Moins">−</button>
            <span class="cart-item__qty-count">${item.quantity}</span>
            <button class="cart-item__qty-btn" data-qty-change="1" data-key="${item.key}" data-qty="${item.quantity}" aria-label="Plus">+</button>
          </div>
        </div>
        <button class="cart-item__remove" data-cart-remove data-key="${item.key}" aria-label="Supprimer ${escHtml(item.title)}">&#215;</button>
      `;
      itemsEl.appendChild(div);
    });

    /* update header badge */
    document.querySelectorAll('[data-cart-count]').forEach(el => el.textContent = cart.item_count);
  }

  /* ---- CHANGE QTY ---- */
  itemsEl.addEventListener('click', e => {
    const btn = e.target.closest('[data-qty-change]');
    const rem = e.target.closest('[data-cart-remove]');

    if (btn) {
      const key = btn.dataset.key;
      const current = parseInt(btn.dataset.qty, 10);
      const delta = parseInt(btn.dataset.qtyChange, 10);
      const newQty = Math.max(0, current + delta);
      updateItem(key, newQty);
    }

    if (rem) {
      updateItem(rem.dataset.key, 0);
    }
  });

  function updateItem(key, quantity) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity })
    })
    .then(r => r.json())
    .then(cart => renderCart(cart));
  }

  /* ---- HELPERS ---- */
  function formatMoney(cents) {
    return (cents / 100).toLocaleString('fr-FR', { style: 'currency', currency: 'EUR' });
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
})();
</script>
