{%- assign title_parts = section.settings.title | split: '**' -%}
<section class="section">
  <div class="container">
    <div class="section-header fade-up">
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title">
        {%- for p in title_parts -%}{%- if forloop.index0 == 1 -%}<em>{{ p }}</em>{%- else -%}{{ p }}{%- endif -%}{%- endfor -%}
      </h2>
      <p class="section-desc">{{ section.settings.description }}</p>
      <div class="section-divider"></div>
    </div>
    <div class="blog-grid">
      {%- for block in section.blocks -%}
        <article class="blog-card fade-up" style="transition-delay:{{ forloop.index0 | times: 100 }}ms" {{ block.shopify_attributes }}>
          <div class="blog-img">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | img_url: '600x400', crop: 'center' | img_tag: block.settings.title, 'loading="lazy" width="600" height="400"' }}
            {%- else -%}
              <img src="{{ 'hero-main.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" width="600" height="400" loading="lazy">
            {%- endif -%}
          </div>
          <div class="blog-body">
            <p class="blog-cat">{{ block.settings.category }}</p>
            <h3 class="blog-title"><a href="{{ block.settings.url | default: '/blogs/news' }}">{{ block.settings.title }}</a></h3>
            <p class="blog-excerpt">{{ block.settings.excerpt }}</p>
          </div>
        </article>
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
      <div style="text-align:center;margin-top:2.5rem">
        <a href="{{ section.settings.cta_url | default: '/blogs/news' }}" class="btn btn--outline btn--lg">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog vedette",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Accroche", "default": "Le journal Octipa" },
    { "type": "textarea", "id": "title", "label": "Titre (**italic**)", "default": "Nos **conseils beauté**" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Conseils d'experts, rituels beauté et actualités de nos formulations." },
    { "type": "text", "id": "cta_label", "label": "Bouton voir tout", "default": "Voir tous les articles" },
    { "type": "url", "id": "cta_url", "label": "Lien bouton", "default": "/blogs/news" }
  ],
  "blocks": [{
    "type": "article",
    "name": "Article",
    "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "category", "label": "Catégorie", "default": "Routine" },
      { "type": "text", "id": "title", "label": "Titre", "default": "5 gestes pour une peau éclatante" },
      { "type": "textarea", "id": "excerpt", "label": "Extrait", "default": "Découvrez les rituels de soin qui font vraiment la différence pour une peau lumineuse." },
      { "type": "url", "id": "url", "label": "Lien article" }
    ]
  }],
  "presets": [{
    "name": "Blog vedette",
    "blocks": [
      { "type": "article", "settings": { "category": "Routine", "title": "5 gestes pour une peau éclatante au quotidien", "excerpt": "Découvrez les rituels de soin qui font vraiment la différence pour une peau lumineuse et hydratée." } },
      { "type": "article", "settings": { "category": "Ingrédients", "title": "L'huile de rosier muscat, l'or de nos formules", "excerpt": "Zoom sur cet ingrédient star sélectionné pour ses propriétés régénératrices exceptionnelles." } },
      { "type": "article", "settings": { "category": "Conseil", "title": "Comment adapter sa routine selon les saisons", "excerpt": "Votre peau a des besoins différents en hiver et en été. Voici comment ajuster votre routine beauté." } }
    ]
  }]
}
{% endschema %}
