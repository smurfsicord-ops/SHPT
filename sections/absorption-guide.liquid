{%- assign title_parts = section.settings.title | split: '**' -%}
<section class="section section-bg">
  <div class="container">
    <div class="absorption-grid">
      <div>
        <p class="section-eyebrow fade-up">{{ section.settings.eyebrow }}</p>
        <h2 class="section-title fade-up" style="text-align:left;transition-delay:80ms">
          {%- for p in title_parts -%}{%- if forloop.index0 == 1 -%}<em>{{ p }}</em>{%- else -%}{{ p }}{%- endif -%}{%- endfor -%}
        </h2>
        <p style="font-size:var(--text-base);color:var(--color-text-muted);max-width:44ch;line-height:1.75;margin-bottom:2rem" class="fade-up">{{ section.settings.description }}</p>
        <div class="absorption-levels">
          {%- for block in section.blocks -%}
            <div class="absorption-level fade-up" style="transition-delay:{{ forloop.index0 | times: 80 | plus: 150 }}ms" {{ block.shopify_attributes }}>
              <div class="drops">
                {%- for i in (1..4) -%}
                  <span class="drop{% if i <= block.settings.drops %} full{% endif %}"></span>
                {%- endfor -%}
              </div>
              <div class="absorption-info">
                <div class="absorption-name">{{ block.settings.name }}</div>
                <div class="absorption-sub">{{ block.settings.description }}</div>
              </div>
              <span class="absorption-badge" style="background:{{ block.settings.badge_bg }};color:{{ block.settings.badge_color }}">{{ block.settings.badge }}</span>
            </div>
          {%- endfor -%}
        </div>
        <div style="margin-top:2rem">
          <a href="{{ section.settings.cta_url }}" class="btn btn--primary btn--lg fade-up" style="transition-delay:400ms">{{ section.settings.cta_label }}</a>
        </div>
      </div>
      <div class="absorption-visual fade-up" style="transition-delay:200ms">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | img_url: '700x875', crop: 'center' | img_tag: 'Guide absorption', 'loading="lazy" width="700" height="875"' }}
        {%- else -%}
          <img src="{{ 'hero-secondary.jpg' | asset_url }}" alt="Guide absorption" width="700" height="875" loading="lazy">
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guide absorption",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Accroche", "default": "Comment choisir" },
    { "type": "textarea", "id": "title", "label": "Titre (**italic**)", "default": "Trouvez votre **flux idéal**" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Chaque peau est unique. Nos formules s'adaptent à votre type de peau pour une absorption optimale." },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "cta_label", "label": "Texte bouton", "default": "Faire le diagnostic" },
    { "type": "url", "id": "cta_url", "label": "Lien bouton", "default": "/pages/diagnostic" }
  ],
  "blocks": [{
    "type": "level",
    "name": "Niveau d'absorption",
    "settings": [
      { "type": "text", "id": "name", "label": "Nom", "default": "Flux Léger" },
      { "type": "text", "id": "description", "label": "Description", "default": "Peaux normales à mixtes" },
      { "type": "range", "id": "drops", "label": "Niveau (1-4)", "min": 1, "max": 4, "step": 1, "default": 1 },
      { "type": "text", "id": "badge", "label": "Badge", "default": "Absorption 30min" },
      { "type": "text", "id": "badge_bg", "label": "Fond badge (hex)", "default": "#e8f5e9" },
      { "type": "text", "id": "badge_color", "label": "Couleur texte badge (hex)", "default": "#2e7d32" }
    ]
  }],
  "presets": [{
    "name": "Guide absorption",
    "blocks": [
      { "type": "level", "settings": { "name": "Flux Léger", "description": "Peaux normales à mixtes", "drops": 1, "badge": "Absorption 30min", "badge_bg": "#e8f5e9", "badge_color": "#2e7d32" } },
      { "type": "level", "settings": { "name": "Flux Moyen", "description": "Peaux sèches, nutrition ciblée", "drops": 2, "badge": "Absorption 2h", "badge_bg": "#fff8e1", "badge_color": "#f57f17" } },
      { "type": "level", "settings": { "name": "Flux Intense", "description": "Peaux très sèches, réparation", "drops": 3, "badge": "Absorption 4h", "badge_bg": "#fce4ec", "badge_color": "#c62828" } },
      { "type": "level", "settings": { "name": "Flux Nuit", "description": "Soin régénérateur nocturne", "drops": 4, "badge": "Action nocturne", "badge_bg": "#ede7f6", "badge_color": "#4527a0" } }
    ]
  }]
}
{% endschema %}
