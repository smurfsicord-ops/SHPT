{%- comment -%}
  Section: cart-upsell
  Bloc upsell affiché sur la page panier, entièrement configurable depuis l'éditeur de thème.
{%- endcomment -%}

{%- if cart.item_count > 0 -%}

  {%- liquid
    assign upsell_product = nil

    if section.settings.product != blank
      assign upsell_product = section.settings.product
    else
      assign cart_product_ids = cart.items | map: 'product_id'
      for product in collections.all.products limit: 20
        unless cart_product_ids contains product.id
          if upsell_product == nil
            assign upsell_product = product
          endif
        endunless
      endfor
    endif
  -%}

  {%- if upsell_product != nil -%}
    <div class="octi-upsell" id="octi-upsell">
      <div class="octi-upsell__header">
        <span class="octi-upsell__badge">{{ section.settings.badge_text }}</span>
        {%- if section.settings.show_close -%}
          <button
            class="octi-upsell__close"
            onclick="this.closest('.octi-upsell').style.display='none'"
            aria-label="Fermer"
          >&times;</button>
        {%- endif -%}
      </div>

      <div class="octi-upsell__inner">
        {%- if upsell_product.featured_image -%}
          <div class="octi-upsell__img-wrap">
            <img
              src="{{ upsell_product.featured_image | image_url: width: 320 }}"
              alt="{{ upsell_product.title | escape }}"
              width="90"
              height="90"
              loading="lazy"
              class="octi-upsell__img"
            >
          </div>
        {%- endif -%}

        <div class="octi-upsell__info">
          <p class="octi-upsell__title">{{ upsell_product.title }}</p>
          <p class="octi-upsell__price">{{ upsell_product.price | money }}</p>
          {%- if section.settings.show_description and upsell_product.description != blank -%}
            <p class="octi-upsell__desc">{{ upsell_product.description | strip_html | truncate: 90 }}</p>
          {%- endif -%}
        </div>

        <div class="octi-upsell__action">
          {%- if upsell_product.variants.size > 1 -%}
            <a href="{{ upsell_product.url }}" class="octi-upsell__btn">
              {{ section.settings.btn_label_variants }}
            </a>
          {%- else -%}
            <form action="/cart/add" method="post">
              <input type="hidden" name="id" value="{{ upsell_product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="octi-upsell__btn">
                {{ section.settings.btn_label_add }}
              </button>
            </form>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

{%- endif -%}

<style>
.octi-upsell {
  margin-top: 2rem;
  background: #fff;
  border: 1.5px solid #eadfd4;
  border-radius: 20px;
  padding: 20px 24px;
  box-shadow: 0 8px 32px rgba(40,20,10,.07);
  animation: upsell-in .45s cubic-bezier(.16,1,.3,1) both;
}
@keyframes upsell-in {
  from { opacity:0; transform:translateY(14px); }
  to   { opacity:1; transform:translateY(0); }
}
.octi-upsell__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.octi-upsell__badge {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: #a06f5d;
  background: #f7ede7;
  border: 1px solid #edd5c8;
  border-radius: 999px;
  padding: 5px 12px;
}
.octi-upsell__close {
  background: none;
  border: none;
  font-size: 20px;
  color: #b0a09a;
  cursor: pointer;
  line-height: 1;
  padding: 4px 8px;
  border-radius: 8px;
  transition: background .15s;
}
.octi-upsell__close:hover { background: #f3ede8; }
.octi-upsell__inner {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.octi-upsell__img-wrap { flex-shrink: 0; }
.octi-upsell__img {
  width: 90px;
  height: 90px;
  object-fit: cover;
  border-radius: 12px;
  border: 1px solid #eadfd4;
}
.octi-upsell__info {
  flex: 1;
  min-width: 140px;
}
.octi-upsell__title {
  font-size: 15px;
  font-weight: 700;
  color: #1e110a;
  margin: 0 0 4px;
  line-height: 1.3;
}
.octi-upsell__price {
  font-size: 14px;
  font-weight: 600;
  color: #a06f5d;
  margin: 0 0 4px;
}
.octi-upsell__desc {
  font-size: 12px;
  color: #8a7a72;
  margin: 0;
  line-height: 1.5;
}
.octi-upsell__action { flex-shrink: 0; }
.octi-upsell__btn {
  display: inline-block;
  background: #1e110a;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  padding: 12px 20px;
  border-radius: 12px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background .2s, transform .15s;
  white-space: nowrap;
}
.octi-upsell__btn:hover {
  background: #3a2419;
  transform: translateY(-1px);
}
@media (max-width: 600px) {
  .octi-upsell__inner { flex-direction: column; align-items: flex-start; }
  .octi-upsell__action { width: 100%; }
  .octi-upsell__btn { width: 100%; text-align: center; }
}
</style>

{% schema %}
{
  "name": "Upsell panier",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Produit mis en avant"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Produit upsell",
      "info": "Laissez vide pour afficher automatiquement un produit non présent dans le panier."
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Afficher la description",
      "default": true
    },
    {
      "type": "header",
      "content": "Textes"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texte du badge",
      "default": "✦ Souvent choisi ensemble"
    },
    {
      "type": "text",
      "id": "btn_label_add",
      "label": "Bouton \u2014 ajout direct",
      "default": "Ajouter au panier"
    },
    {
      "type": "text",
      "id": "btn_label_variants",
      "label": "Bouton \u2014 plusieurs variantes",
      "default": "Voir le produit →"
    },
    {
      "type": "header",
      "content": "Options"
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Afficher le bouton fermer",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Upsell panier"
    }
  ]
}
{% endschema %}
