<section class="octi-diag">
  <div class="octi-diag__bg-deco" aria-hidden="true">
    <span class="octi-deco octi-deco--1"></span>
    <span class="octi-deco octi-deco--2"></span>
    <span class="octi-deco octi-deco--3"></span>
  </div>

  <div class="octi-diag__wrap">

    <!-- INTRO -->
    <div id="diag-intro" class="octi-panel octi-panel--active">
      <span class="octi-badge">✦ Diagnostic gratuit</span>
      <h1 class="octi-diag__h1">Trouvez la culotte<br><em>faite pour vous</em></h1>
      <p class="octi-diag__lead">Répondez à 5 questions et recevez votre recommandation personnalisée en moins de 2 minutes.</p>
      <div class="octi-intro__pills">
        <span>⏱ 2 minutes</span>
        <span>🎯 100% personnalisé</span>
        <span>🆓 Gratuit</span>
      </div>
      <button class="octi-cta" onclick="octiQ.start()">
        <span>Commencer le diagnostic</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>

    <!-- QUIZ -->
    <div id="diag-quiz" class="octi-panel">
      <div class="octi-diag__topbar">
        <div class="octi-diag__topbar-info">
          <span id="diag-label" class="octi-step-label">Question 1 / 5</span>
          <span id="diag-pct" class="octi-pct">20%</span>
        </div>
        <div class="octi-diag__bar"><div id="diag-fill"></div></div>
      </div>

      <div id="diag-q-wrap">
        <div class="octi-q" id="qq0" data-icon="🌸">
          <p class="octi-q__icon">🌸</p>
          <h2>Dans quelle situation porterez-vous votre culotte&nbsp;?</h2>
          <div class="octi-q__opts">
            <button onclick="octiQ.pick('usage','daily')">
              <span class="opt-icon">☀️</span>
              <span class="opt-label">Au quotidien</span>
            </button>
            <button onclick="octiQ.pick('usage','night')">
              <span class="opt-icon">🌙</span>
              <span class="opt-label">La nuit</span>
            </button>
            <button onclick="octiQ.pick('usage','sport')">
              <span class="opt-icon">🏃‍♀️</span>
              <span class="opt-label">Pendant le sport</span>
            </button>
            <button onclick="octiQ.pick('usage','mixed')">
              <span class="opt-icon">✨</span>
              <span class="opt-label">Un peu tout</span>
            </button>
          </div>
        </div>

        <div class="octi-q" id="qq1" data-icon="💧">
          <p class="octi-q__icon">💧</p>
          <h2>Quel niveau de flux recherchez-vous&nbsp;?</h2>
          <div class="octi-q__opts">
            <button onclick="octiQ.pick('flow','light')">
              <span class="opt-icon">🩵</span>
              <span class="opt-label">Léger</span>
            </button>
            <button onclick="octiQ.pick('flow','medium')">
              <span class="opt-icon">💙</span>
              <span class="opt-label">Modéré</span>
            </button>
            <button onclick="octiQ.pick('flow','heavy')">
              <span class="opt-icon">🔵</span>
              <span class="opt-label">Élevé</span>
            </button>
            <button onclick="octiQ.pick('flow','variable')">
              <span class="opt-icon">🌊</span>
              <span class="opt-label">Variable</span>
            </button>
          </div>
        </div>

        <div class="octi-q" id="qq2" data-icon="⭐">
          <p class="octi-q__icon">⭐</p>
          <h2>Quelle qualité est la plus importante&nbsp;?</h2>
          <div class="octi-q__opts">
            <button onclick="octiQ.pick('priority','comfort')">
              <span class="opt-icon">🤍</span>
              <span class="opt-label">Le confort</span>
            </button>
            <button onclick="octiQ.pick('priority','discreet')">
              <span class="opt-icon">🫧</span>
              <span class="opt-label">La discrétion</span>
            </button>
            <button onclick="octiQ.pick('priority','security')">
              <span class="opt-icon">🛡️</span>
              <span class="opt-label">La sécurité</span>
            </button>
            <button onclick="octiQ.pick('priority','style')">
              <span class="opt-icon">🌹</span>
              <span class="opt-label">Le style</span>
            </button>
          </div>
        </div>

        <div class="octi-q" id="qq3" data-icon="🌿">
          <p class="octi-q__icon">🌿</p>
          <h2>Quelle matière préférez-vous&nbsp;?</h2>
          <div class="octi-q__opts">
            <button onclick="octiQ.pick('fabric','cotton')">
              <span class="opt-icon">🌼</span>
              <span class="opt-label">Coton doux</span>
            </button>
            <button onclick="octiQ.pick('fabric','technical')">
              <span class="opt-icon">⚡</span>
              <span class="opt-label">Technique</span>
            </button>
            <button onclick="octiQ.pick('fabric','soft')">
              <span class="opt-icon">🧸</span>
              <span class="opt-label">Très souple</span>
            </button>
            <button onclick="octiQ.pick('fabric','any')">
              <span class="opt-icon">🤷‍♀️</span>
              <span class="opt-label">Pas de préférence</span>
            </button>
          </div>
        </div>

        <div class="octi-q" id="qq4" data-icon="🎁">
          <p class="octi-q__icon">🎁</p>
          <h2>Comment souhaitez-vous commencer&nbsp;?</h2>
          <div class="octi-q__opts">
            <button onclick="octiQ.pick('start','single')">
              <span class="opt-icon">1️⃣</span>
              <span class="opt-label">Un seul modèle</span>
            </button>
            <button onclick="octiQ.pick('start','pack')">
              <span class="opt-icon">📦</span>
              <span class="opt-label">Un pack</span>
            </button>
            <button onclick="octiQ.pick('start','best')">
              <span class="opt-icon">🏆</span>
              <span class="opt-label">La meilleure option</span>
            </button>
            <button onclick="octiQ.pick('start','compare')">
              <span class="opt-icon">🔍</span>
              <span class="opt-label">Comparer</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- RÉSULTAT -->
    <div id="diag-result" class="octi-panel"></div>

  </div>
</section>

<style>
/* ── Variables ── */
.octi-diag {
  --c-bg: #f8f4ef;
  --c-card: #ffffff;
  --c-dark: #1e110a;
  --c-terr: #b7806e;
  --c-terr-lt: #f7ede7;
  --c-muted: #6e5d55;
  --c-border: #eadfd4;
  --c-bar1: #d4a090;
  --c-bar2: #1e110a;
  --radius: 20px;
  --shadow: 0 20px 60px rgba(40,20,10,.09);
  position: relative;
  background: var(--c-bg);
  min-height: 90vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  overflow: hidden;
}

/* ── Déco background ── */
.octi-diag__bg-deco { position:absolute;inset:0;pointer-events:none;overflow:hidden; }
.octi-deco {
  position: absolute;
  border-radius: 50%;
  opacity: .45;
  filter: blur(70px);
  animation: deco-float 12s ease-in-out infinite alternate;
}
.octi-deco--1 { width:500px;height:500px;background:radial-gradient(circle,#f0d5c8,transparent 70%);top:-120px;right:-100px; }
.octi-deco--2 { width:360px;height:360px;background:radial-gradient(circle,#e8d4c0,transparent 70%);bottom:-80px;left:-80px;animation-delay:-4s; }
.octi-deco--3 { width:260px;height:260px;background:radial-gradient(circle,#f5e6da,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);animation-delay:-8s; }
@keyframes deco-float { 0%{transform:scale(1) translateY(0)} 100%{transform:scale(1.12) translateY(-20px)} }
.octi-deco--3 { animation-name: deco-float3; }
@keyframes deco-float3 { 0%{transform:translate(-50%,-50%) scale(1)} 100%{transform:translate(-50%,-55%) scale(1.1)} }

/* ── Card ── */
.octi-diag__wrap {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 760px;
  background: var(--c-card);
  border-radius: 28px;
  padding: clamp(32px, 5vw, 56px);
  box-shadow: var(--shadow);
  border: 1px solid var(--c-border);
}

/* ── Panels ── */
.octi-panel { display:none; }
.octi-panel--active { display:block; animation: panel-in .5s cubic-bezier(.16,1,.3,1) both; }
@keyframes panel-in {
  from { opacity:0; transform:translateY(18px); }
  to   { opacity:1; transform:translateY(0); }
}

/* ── Badge ── */
.octi-badge {
  display: inline-block;
  background: var(--c-terr-lt);
  color: var(--c-terr);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 999px;
  border: 1px solid #edd5c8;
  margin-bottom: 20px;
}

/* ── Intro ── */
.octi-diag__h1 {
  font-size: clamp(34px, 5.5vw, 56px);
  line-height: 1.05;
  font-weight: 800;
  color: var(--c-dark);
  margin: 0 0 16px;
  letter-spacing: -.02em;
}
.octi-diag__h1 em { font-style: italic; color: var(--c-terr); }
.octi-diag__lead {
  font-size: 17px;
  color: var(--c-muted);
  line-height: 1.75;
  max-width: 52ch;
  margin: 0 0 24px;
}
.octi-intro__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 32px;
}
.octi-intro__pills span {
  background: #faf6f2;
  border: 1px solid var(--c-border);
  border-radius: 999px;
  padding: 8px 16px;
  font-size: 13px;
  font-weight: 600;
  color: var(--c-muted);
}

/* ── CTA ── */
.octi-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--c-dark);
  color: #fff;
  border: none;
  border-radius: 14px;
  padding: 17px 28px;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  transition: background .2s, transform .15s, box-shadow .2s;
  box-shadow: 0 4px 20px rgba(30,17,10,.2);
}
.octi-cta:hover {
  background: #3a2419;
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(30,17,10,.28);
}
.octi-cta svg { transition: transform .2s; }
.octi-cta:hover svg { transform: translateX(4px); }

/* ── Progress ── */
.octi-diag__topbar { margin-bottom: 32px; }
.octi-diag__topbar-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.octi-step-label {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: #9a8880;
}
.octi-pct {
  font-size: 12px;
  font-weight: 800;
  color: var(--c-terr);
}
.octi-diag__bar {
  width: 100%;
  height: 8px;
  background: #f1e8e0;
  border-radius: 999px;
  overflow: hidden;
}
.octi-diag__bar div {
  height: 100%;
  background: linear-gradient(90deg, var(--c-bar1), var(--c-bar2));
  border-radius: 999px;
  width: 20%;
  transition: width .5s cubic-bezier(.16,1,.3,1);
}

/* ── Question ── */
.octi-q { animation: panel-in .4s cubic-bezier(.16,1,.3,1) both; }
.octi-q__icon { font-size: 36px; margin: 0 0 12px; line-height: 1; }
.octi-q h2 {
  font-size: clamp(22px, 3vw, 32px);
  color: var(--c-dark);
  font-weight: 700;
  margin: 0 0 24px;
  line-height: 1.2;
  letter-spacing: -.01em;
}
.octi-q__opts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.octi-q__opts button {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8px;
  background: #fdfaf7;
  border: 1.5px solid var(--c-border);
  border-radius: 16px;
  padding: 20px 18px;
  cursor: pointer;
  transition: all .2s cubic-bezier(.16,1,.3,1);
  text-align: left;
}
.octi-q__opts button:hover {
  border-color: var(--c-terr);
  background: #fff7f4;
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(183,128,110,.15);
}
.octi-q__opts button:active { transform: translateY(-1px); }
.opt-icon { font-size: 26px; line-height: 1; }
.opt-label { font-size: 14px; font-weight: 600; color: var(--c-dark); line-height: 1.3; }

/* ── Résultat ── */
.octi-result__confetti {
  font-size: 32px;
  margin-bottom: 12px;
  animation: confetti-bounce .6s cubic-bezier(.16,1,.3,1);
}
@keyframes confetti-bounce { 0%{transform:scale(0) rotate(-10deg)} 70%{transform:scale(1.15) rotate(3deg)} 100%{transform:scale(1)} }
.octi-result__badge {
  display: inline-block;
  background: var(--c-terr-lt);
  color: var(--c-terr);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 999px;
  border: 1px solid #edd5c8;
  margin-bottom: 16px;
}
.octi-result__h2 {
  font-size: clamp(26px, 4vw, 42px);
  font-weight: 800;
  color: var(--c-dark);
  margin: 0 0 14px;
  line-height: 1.1;
  letter-spacing: -.02em;
}
.octi-result__p {
  font-size: 16px;
  color: var(--c-muted);
  line-height: 1.8;
  margin: 0 0 24px;
  max-width: 54ch;
}
.octi-result__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 32px;
}
.octi-result__chips span {
  padding: 9px 16px;
  border-radius: 999px;
  background: var(--c-terr-lt);
  border: 1px solid #edd5c8;
  font-size: 13px;
  font-weight: 700;
  color: #7a4f41;
}
.octi-result__divider {
  height: 1px;
  background: var(--c-border);
  margin: 0 0 28px;
}
.octi-result__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
.octi-result__actions a {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 16px 26px;
  background: var(--c-dark);
  color: #fff;
  text-decoration: none;
  font-weight: 700;
  font-size: 15px;
  border-radius: 14px;
  transition: background .2s, transform .15s;
  box-shadow: 0 4px 18px rgba(30,17,10,.18);
}
.octi-result__actions a:hover { background:#3a2419; transform:translateY(-2px); }
.octi-result__actions button {
  padding: 16px 26px;
  background: #fff;
  border: 1.5px solid var(--c-border);
  color: var(--c-dark);
  font-weight: 700;
  font-size: 15px;
  border-radius: 14px;
  cursor: pointer;
  transition: background .2s, border-color .2s;
}
.octi-result__actions button:hover { background:#f8f4ef; border-color:#d4c4ba; }

/* ── Responsive ── */
@media (max-width: 600px) {
  .octi-diag__wrap { padding: 28px 20px; border-radius: 20px; }
  .octi-q__opts { grid-template-columns: 1fr; }
  .octi-intro__pills span { font-size:12px; }
}
</style>

<script>
var octiQ={
  step:0,
  answers:{},
  profiles:{
    night:{
      emoji:'🌙',
      tag:'Votre recommandation',
      title:'Protection Nuit & Flux Intense',
      text:'Absorption maximale, coupe enveloppante, tient toute la nuit sans aucune fuite. Idéale pour les flux abondants.',
      chips:['Jusqu\'à 300ml','Coupe nuit','Ultra sécurisée','Bambou doux'],
      url:'/collections/all'
    },
    sport:{
      emoji:'🏃\u200d♀️',
      tag:'Votre recommandation',
      title:'Modèle Sport & Activité',
      text:'Respirante, maintien parfait, absorption fiable pendant l\'effort. Reste en place quelle que soit l\'intensité.',
      chips:['Matière technique','Respirante','Maintien actif','Flux modéré'],
      url:'/collections/all'
    },
    elegant:{
      emoji:'🌹',
      tag:'Votre recommandation',
      title:'Modèle Discret & Élégant',
      text:'Fine, invisible sous vos vêtements, stylée pour toutes les occasions du quotidien.',
      chips:['Ultra-fine','Invisible','Stylée','Quotidien'],
      url:'/collections/all'
    },
    pack:{
      emoji:'🎁',
      tag:'Votre recommandation',
      title:'Pack Découverte Recommandé',
      text:'2 à 4 modèles complémentaires pour tester et trouver votre favori au meilleur prix.',
      chips:['2-4 modèles','Économique','-15%','Satisfait ou remboursé'],
      url:'/collections/all'
    },
    comfort:{
      emoji:'🤍',
      tag:'Votre recommandation',
      title:'Modèle Confort Quotidien',
      text:'Doux, rassurant, polyvalent. Le plus plébiscité pour un usage régulier tout au long de la journée.',
      chips:['Confort longue durée','Quotidien','Flux équilibré','Discrète'],
      url:'/collections/all'
    }
  },

  show:function(id){
    var panels=['diag-intro','diag-quiz','diag-result'];
    panels.forEach(function(p){
      var el=document.getElementById(p);
      if(el){el.classList.remove('octi-panel--active');el.style.display='none';}
    });
    var target=document.getElementById(id);
    if(target){target.style.display='block';setTimeout(function(){target.classList.add('octi-panel--active');},10);}
  },

  start:function(){
    this.step=0;this.answers={};
    this.show('diag-quiz');
    this.render();
  },

  pick:function(k,v){
    this.answers[k]=v;
    var btn=event.currentTarget;
    btn.style.background='#fff4f0';
    btn.style.borderColor='#b7806e';
    var self=this;
    setTimeout(function(){self.step++;if(self.step>=5){self.result();}else{self.render();}},260);
  },

  render:function(){
    for(var i=0;i<5;i++){
      var el=document.getElementById('qq'+i);
      if(el) el.style.display=(i===this.step)?'block':'none';
    }
    var pct=Math.round((this.step+1)/5*100);
    document.getElementById('diag-label').textContent='Question '+(this.step+1)+' / 5';
    document.getElementById('diag-pct').textContent=pct+'%';
    document.getElementById('diag-fill').style.width=pct+'%';
  },

  compute:function(){
    var a=this.answers;
    if(a.usage==='night'||a.flow==='heavy') return'night';
    if(a.usage==='sport'||a.fabric==='technical') return'sport';
    if(a.start==='pack'||a.start==='compare') return'pack';
    if(a.priority==='style'||a.priority==='discreet') return'elegant';
    return'comfort';
  },

  result:function(){
    var p=this.profiles[this.compute()];
    var chips=p.chips.map(function(c){return'<span>'+c+'</span>';}).join('');
    document.getElementById('diag-result').innerHTML=
      '<div class="octi-result__confetti">'+p.emoji+'</div>'
      +'<div class="octi-result__badge">'+p.tag+'</div>'
      +'<h2 class="octi-result__h2">'+p.title+'</h2>'
      +'<p class="octi-result__p">'+p.text+'</p>'
      +'<div class="octi-result__chips">'+chips+'</div>'
      +'<div class="octi-result__divider"></div>'
      +'<div class="octi-result__actions">'
        +'<a href="'+p.url+'">Voir la recommandation <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>'
        +'<button onclick="octiQ.start()">Recommencer</button>'
      +'</div>';
    this.show('diag-result');
  }
};

document.addEventListener('DOMContentLoaded',function(){
  ['diag-intro','diag-quiz','diag-result'].forEach(function(id){
    var el=document.getElementById(id);
    if(el){el.style.display='none';el.classList.add('octi-panel');}
  });
  var intro=document.getElementById('diag-intro');
  if(intro){intro.style.display='block';setTimeout(function(){intro.classList.add('octi-panel--active');},10);}
  for(var i=1;i<5;i++){var q=document.getElementById('qq'+i);if(q)q.style.display='none';}
});
</script>

{% schema %}
{
  "name": "Quiz Diagnostic",
  "settings": []
}
{% endschema %}
