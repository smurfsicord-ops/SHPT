{%- comment -%}
  Section: header
  Description: En-tête sticky avec annonce bar, logo, nav, panier
  Schema: announcement, logo_text, menu
{%- endcomment -%}

<div class="announcement-bar">{{ section.settings.announcement }}</div>

<header id="SiteHeader" class="site-header">
  <div class="header-inner">
    <a href="{{ routes.root_url }}" class="header-logo" aria-label="{{ shop.name }}">
      <svg width="28" height="28" viewBox="0 0 30 30" fill="none" aria-hidden="true">
        <circle cx="15" cy="15" r="13" fill="#c4756a" opacity=".15"/>
        <path d="M15 5 C10 5 7 10 7 15 C7 21 11 25 15 25 C19 25 23 21 23 15 C23 10 20 5 15 5Z" fill="#c4756a" opacity=".4"/>
        <path d="M15 8 C12 8 10 12 10 15 C10 19 12 23 15 23 C18 23 20 19 20 15 C20 12 18 8 15 8Z" fill="#c4756a"/>
      </svg>
      {{ section.settings.logo_text }}
    </a>

    <nav class="header-nav" aria-label="Navigation principale">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="header-actions">
      <a href="{{ routes.account_url }}" class="header-icon-btn" aria-label="Mon compte">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <div class="cart-btn-wrap">
        <button id="CartBtn" class="header-icon-btn" aria-label="Ouvrir le panier">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="cart-count" aria-label="{{ cart.item_count }} article(s) dans le panier">{{ cart.item_count }}</span>
          {%- endif -%}
        </button>
      </div>
      <button id="MobileMenuBtn" class="header-icon-btn mobile-menu-btn" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="MobileNav">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "En-tête",
  "settings": [
    { "type": "text", "id": "announcement", "label": "Texte bandeau", "default": "📦 Livraison offerte dès 49€ — Emballage discret garanti" },
    { "type": "text", "id": "logo_text",    "label": "Nom de la marque", "default": "Octipa" },
    { "type": "link_list", "id": "menu",   "label": "Menu principal",  "default": "main-menu" }
  ]
}
{% endschema %}
