{%- comment -%}
  Section: testimonials
  Description: Grille d'avis clients Octipa — cartes élégantes avec avatar, étoiles, citation
  Schema: eyebrow, title, description + blocks (review)
{%- endcomment -%}

{%- liquid
  assign title_parts = section.settings.title | split: '**'
-%}

<section class="section-testimonials">
  <div class="container">

    <div class="testi-header fade-up">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">
        {%- for p in title_parts -%}
          {%- if forloop.index0 == 1 -%}<em>{{ p }}</em>{%- else -%}{{ p }}{%- endif -%}
        {%- endfor -%}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="section-desc">{{ section.settings.description }}</p>
      {%- endif -%}
      <div class="section-divider"></div>

      <div class="testi-global-rating">
        <div class="testi-stars-row">★★★★★</div>
        <p class="testi-rating-label">4,9/5 · Plus de 2 000 avis vérifiés</p>
      </div>
    </div>

    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        {%- assign initials = block.settings.author | split: ' ' -%}
        {%- assign letter = initials[0] | slice: 0 -%}

        <article
          class="testi-card fade-up"
          style="transition-delay:{{ forloop.index0 | times: 80 }}ms"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} QUOTE ICON {%- endcomment -%}
          <div class="testi-card__quote-icon" aria-hidden="true">
            <svg width="28" height="22" viewBox="0 0 28 22" fill="none">
              <path d="M0 22V13.4C0 9.8 0.9 6.83333 2.7 4.5C4.56667 2.16667 7.13333 0.633333 10.4 0L11.6 2.2C9.6 2.73333 8 3.73333 6.8 5.2C5.66667 6.6 5.06667 8.13333 5 9.8H10.4V22H0ZM16.4 22V13.4C16.4 9.8 17.3 6.83333 19.1 4.5C20.9667 2.16667 23.5333 0.633333 26.8 0L28 2.2C26 2.73333 24.4 3.73333 23.2 5.2C22.0667 6.6 21.4667 8.13333 21.4 9.8H26.8V22H16.4Z" fill="currentColor"/>
            </svg>
          </div>

          {%- comment -%} ÉTOILES {%- endcomment -%}
          <div class="testi-card__stars" aria-label="{{ block.settings.stars }} étoiles sur 5">
            {%- for i in (1..block.settings.stars) -%}★{%- endfor -%}
            {%- assign empty = 5 | minus: block.settings.stars -%}
            {%- for i in (1..empty) -%}<span class="star--empty">★</span>{%- endfor -%}
          </div>

          {%- comment -%} TEXTE {%- endcomment -%}
          <blockquote class="testi-card__text">
            {{ block.settings.text | escape }}
          </blockquote>

          {%- comment -%} AUTEUR {%- endcomment -%}
          <footer class="testi-card__footer">
            <div class="testi-card__avatar" aria-hidden="true">{{ letter | upcase }}</div>
            <div class="testi-card__meta">
              <span class="testi-card__author">{{ block.settings.author }}</span>
              <span class="testi-card__location">{{ block.settings.city }}</span>
              {%- if block.settings.verified -%}
                <span class="testi-card__verified">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Achat vérifié
                </span>
              {%- endif -%}
            </div>
          </footer>
        </article>
      {%- endfor -%}
    </div>

  </div>
</section>

{% stylesheet %}
/* ============================================================
   SECTION TESTIMONIALS — Octipa
   Grille 3 colonnes desktop, 2 tablette, 1 mobile
   ============================================================ */

.section-testimonials {
  padding-block: clamp(3.5rem, 7vw, 6rem);
  background: var(--color-bg, #f7f6f2);
}

/* HEADER */
.testi-header {
  text-align: center;
  max-width: 600px;
  margin-inline: auto;
  margin-bottom: clamp(2rem, 4vw, 3.5rem);
}

.testi-global-rating {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  margin-top: 1.25rem;
  background: var(--color-surface, #fff);
  border: 1px solid rgba(0,0,0,.08);
  border-radius: 999px;
  padding: 8px 24px;
}

.testi-stars-row {
  color: #c9824a;
  font-size: 1rem;
  letter-spacing: 2px;
}

.testi-rating-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--color-text-muted, #7a7974);
  text-transform: uppercase;
  letter-spacing: .07em;
  margin: 0;
}

/* GRILLE */
.testimonials-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(1rem, 2.5vw, 1.5rem);
}

@media (min-width: 640px) {
  .testimonials-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .testimonials-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* CARTE */
.testi-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  background: var(--color-surface, #fff);
  border: 1px solid rgba(0,0,0,.07);
  border-radius: 16px;
  padding: clamp(1.25rem, 3vw, 1.75rem);
  box-shadow: 0 2px 8px rgba(0,0,0,.04), 0 8px 24px rgba(0,0,0,.03);
  transition: transform 220ms ease, box-shadow 220ms ease;
  position: relative;
  overflow: hidden;
}

.testi-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, #c9824a, #e8b08a);
  opacity: 0;
  transition: opacity 220ms ease;
}

.testi-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 6px 20px rgba(0,0,0,.08), 0 16px 40px rgba(0,0,0,.05);
}

.testi-card:hover::before {
  opacity: 1;
}

/* QUOTE ICON */
.testi-card__quote-icon {
  color: #e8d5c4;
  line-height: 1;
}

/* ÉTOILES */
.testi-card__stars {
  font-size: 1rem;
  color: #c9824a;
  letter-spacing: 2px;
  line-height: 1;
}

.star--empty {
  color: #ddd;
}

/* TEXTE */
.testi-card__text {
  font-size: clamp(0.9rem, 0.85rem + 0.25vw, 1rem);
  line-height: 1.7;
  color: var(--color-text, #28251d);
  margin: 0;
  flex: 1;
  font-style: italic;
}

/* FOOTER AUTEUR */
.testi-card__footer {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-top: 1rem;
  border-top: 1px solid rgba(0,0,0,.07);
  margin-top: auto;
}

.testi-card__avatar {
  flex-shrink: 0;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: linear-gradient(135deg, #c9824a, #e8b08a);
  color: #fff;
  font-size: 1rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.testi-card__meta {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.testi-card__author {
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-text, #28251d);
  display: block;
}

.testi-card__location {
  font-size: 0.75rem;
  color: var(--color-text-muted, #7a7974);
  display: block;
}

.testi-card__verified {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.68rem;
  font-weight: 600;
  color: #437a22;
  text-transform: uppercase;
  letter-spacing: .06em;
  margin-top: 2px;
}

.testi-card__verified svg {
  color: #437a22;
  flex-shrink: 0;
}

/* ANIMATIONS FADE-UP (si pas déjà dans theme.css) */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

.fade-up {
  opacity: 0;
  animation: fadeUp 0.55s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@media (prefers-reduced-motion: reduce) {
  .fade-up { animation: none; opacity: 1; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Témoignages",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    { "type": "text",     "id": "eyebrow",     "label": "Accroche",          "default": "Elles nous font confiance" },
    { "type": "textarea", "id": "title",        "label": "Titre (**italic**)", "default": "Ce qu'elles **disent de nous**" },
    { "type": "textarea", "id": "description",  "label": "Description",       "default": "Plus de 2 000 femmes font confiance à Octipa chaque jour." }
  ],
  "blocks": [{
    "type": "review",
    "name": "Avis",
    "settings": [
      { "type": "range",    "id": "stars",    "label": "Étoiles",        "min": 1, "max": 5, "step": 1, "default": 5 },
      { "type": "textarea", "id": "text",     "label": "Texte de l'avis","default": "Enfin une solution discrète et élégante. Je les porte toute la journée sans y penser." },
      { "type": "text",     "id": "author",   "label": "Prénom Initiale","default": "Martine G." },
      { "type": "text",     "id": "city",     "label": "Ville",          "default": "Lyon" },
      { "type": "checkbox", "id": "verified", "label": "Achat vérifié",  "default": true }
    ]
  }],
  "presets": [{
    "name": "Témoignages Octipa",
    "blocks": [
      { "type": "review", "settings": { "stars": 5, "text": "Enfin une solution discrète et élégante. Je les porte toute la journée sans y penser.", "author": "Martine G.", "city": "Lyon", "verified": true } },
      { "type": "review", "settings": { "stars": 5, "text": "La qualité est remarquable, on n'a pas l'impression de porter une protection du tout.", "author": "Sylvie D.", "city": "Paris", "verified": true } },
      { "type": "review", "settings": { "stars": 5, "text": "Je recommande vivement à toutes les femmes qui cherchent confort et discrétion au quotidien.", "author": "Chantal R.", "city": "Bordeaux", "verified": true } },
      { "type": "review", "settings": { "stars": 5, "text": "Le pack semaine est parfait, je n'ai plus à y penser. Livraison ultra rapide et discrète.", "author": "Françoise M.", "city": "Nantes", "verified": true } },
      { "type": "review", "settings": { "stars": 5, "text": "Belle matière, coupe parfaite, et surtout vraiment efficace. Je suis ravie de ma commande.", "author": "Isabelle T.", "city": "Toulouse", "verified": true } },
      { "type": "review", "settings": { "stars": 5, "text": "Service client au top et produit qui tient toutes ses promesses. Merci Octipa !", "author": "Julie B.", "city": "Marseille", "verified": true } }
    ]
  }]
}
{% endschema %}
