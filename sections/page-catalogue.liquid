{%- comment -%}
  Section: page-catalogue
  Description: Page catalogue Octipa — grille de produits ajoutables manuellement
               depuis l'éditeur de thème (blocks)
  Shopify 2.0 — chaque block = 1 produit sélectionnable
{%- endcomment -%}

{%- liquid
  assign heading    = section.settings.heading    | default: 'Notre Catalogue'
  assign subheading = section.settings.subheading
  assign columns    = section.settings.columns    | default: '3'
-%}

<section class="page-catalogue">
  <div class="page-catalogue__container">

    {%- comment -%} EN-TÊTE {%- endcomment -%}
    <div class="page-catalogue__header">
      <p class="page-catalogue__eyebrow">Nos produits</p>
      <h1 class="page-catalogue__heading">{{ heading }}</h1>
      {%- if subheading != blank -%}
        <p class="page-catalogue__subheading">{{ subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} GRILLE PRODUITS (blocks) {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <ul class="page-catalogue__grid page-catalogue__grid--{{ columns }}" role="list">
        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          {%- if product != blank -%}
            <li {{ block.shopify_attributes }}>
              {%- render 'card-product', product: product -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- else -%}
      <div class="page-catalogue__empty">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
        <p>Aucun produit ajouté pour l'instant.</p>
        <span class="page-catalogue__empty-hint">Ajoutez des produits depuis l'éditeur de thème → "Ajouter un produit"</span>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
/* ============================================================
   PAGE CATALOGUE — Octipa
   ============================================================ */

.page-catalogue {
  padding-block: clamp(3rem, 6vw, 6rem);
  background: var(--color-bg, #f7f6f2);
}

.page-catalogue__container {
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(1rem, 4vw, 2rem);
}

/* HEADER */
.page-catalogue__header {
  text-align: center;
  margin-bottom: clamp(2rem, 4vw, 3.5rem);
}

.page-catalogue__eyebrow {
  font-size: clamp(0.7rem, 0.65rem + 0.2vw, 0.8rem);
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--color-primary, #01696f);
  margin-bottom: .75rem;
}

.page-catalogue__heading {
  font-family: var(--font-display, Georgia, serif);
  font-size: clamp(1.8rem, 1.2rem + 2.5vw, 3rem);
  font-weight: 700;
  color: var(--color-text, #28251d);
  line-height: 1.15;
  margin-bottom: 1rem;
}

.page-catalogue__subheading {
  font-size: clamp(0.95rem, 0.9rem + 0.2vw, 1.1rem);
  color: var(--color-text-muted, #7a7974);
  max-width: 55ch;
  margin-inline: auto;
  line-height: 1.65;
}

/* GRID */
.page-catalogue__grid {
  display: grid;
  list-style: none;
  gap: clamp(1rem, 2vw, 1.5rem);
  grid-template-columns: repeat(2, 1fr);
}

@media (min-width: 768px) {
  .page-catalogue__grid--2 { grid-template-columns: repeat(2, 1fr); }
  .page-catalogue__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .page-catalogue__grid--4 { grid-template-columns: repeat(4, 1fr); }
}

/* EMPTY */
.page-catalogue__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 14px;
  padding: 80px 20px;
  color: var(--color-text-muted, #7a7974);
  background: #fff;
  border-radius: 16px;
  border: 2px dashed var(--color-border, #d4d1ca);
}

.page-catalogue__empty p {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text, #28251d);
  margin: 0;
}

.page-catalogue__empty-hint {
  font-size: 0.82rem;
  color: var(--color-text-muted, #7a7974);
  max-width: 36ch;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Page Catalogue",
  "tag": "section",
  "class": "section-page-catalogue",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre de la page",
      "default": "Notre Catalogue"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "D\u00e9couvrez notre gamme compl\u00e8te de sous-v\u00eatements Octipa."
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Nombre de colonnes",
      "options": [
        { "value": "2", "label": "2 colonnes" },
        { "value": "3", "label": "3 colonnes" },
        { "value": "4", "label": "4 colonnes" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produit",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "S\u00e9lectionner un produit"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Page Catalogue",
      "blocks": []
    }
  ]
}
{% endschema %}
