{%- comment -%}
  Section: featured-collection
  Description: Grille produits phares Octipa avec vraies collections Shopify
  Schema: eyebrow, title, description, collection, cta_label, cta_url
{%- endcomment -%}

{%- liquid
  assign featured_collection = collections[section.settings.collection]
  assign title_parts         = section.settings.title | split: '**'
  assign products_limit      = section.settings.products_limit | default: 4
-%}

<section class="featured-collection section-spacing">
  <div class="container">
    <div class="section-header fade-up">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">
        {%- for part in title_parts -%}
          {%- if forloop.index0 == 1 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
        {%- endfor -%}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="section-desc">{{ section.settings.description }}</p>
      {%- endif -%}
      <div class="section-divider"></div>
    </div>

    <div class="fc-grid">
      {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
        {%- for product in featured_collection.products limit: products_limit -%}
          {%- render 'card-product', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="card-product card-product--placeholder">
            <div class="card-product__media">{{ 'product-' | append: i | placeholder_svg_tag: 'card-product__placeholder' }}</div>
            <div class="card-product__info">
              <h3 class="card-product__title">Produit exemple {{ i }}</h3>
              <div class="card-product__price-wrapper"><span class="card-product__price">00,00 €</span></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="fc-cta">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--primary btn--lg">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.featured-collection { padding-block: clamp(3rem, 6vw, 5rem); }

.fc-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: clamp(0.75rem, 2vw, 1.25rem);
  margin-block: 2.5rem;
}

@media (min-width: 768px) {
  .fc-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (min-width: 1024px) {
  .fc-grid { grid-template-columns: repeat(4, 1fr); }
}

.fc-cta {
  display: flex;
  justify-content: center;
  margin-top: 2.5rem;
}

.section-header { text-align: center; max-width: 640px; margin-inline: auto; }
.section-eyebrow { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--color-primary, #5b8a8f); margin-bottom: 0.75rem; }
.section-title { font-size: clamp(1.6rem, 1.2rem + 2vw, 2.5rem); font-weight: 700; line-height: 1.15; color: var(--color-text, #28251d); margin-bottom: 1rem; }
.section-title em { font-style: normal; color: var(--color-primary, #5b8a8f); }
.section-desc { font-size: clamp(0.95rem, 0.9rem + 0.2vw, 1.05rem); color: var(--color-text-muted, #7a7974); max-width: 52ch; margin-inline: auto; line-height: 1.7; }
.section-divider { width: 48px; height: 3px; background: var(--color-primary, #5b8a8f); border-radius: 999px; margin: 1.25rem auto 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection vedette",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Accroche", "default": "Notre gamme" },
    { "type": "textarea", "id": "title", "label": "Titre (**italic**)", "default": "Nos culottes **signature**" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Chaque modèle est conçu pour vous offrir confort, discrétion et protection au quotidien." },
    { "type": "collection", "id": "collection", "label": "Collection à afficher" },
    { "type": "range", "id": "products_limit", "label": "Nombre de produits", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "cta_label", "label": "Texte du bouton", "default": "Voir toute la gamme" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" }
  ],
  "presets": [{ "name": "Collection vedette" }]
}
{% endschema %}
