{%- comment -%}
  Snippet: card-product
  Description: Carte produit Octipa — image hover, badge flux, swatch tailles,
               quick add AJAX, wishlist localStorage
  Variables: product, show_vendor, show_rating
  Usage: {% render 'card-product', product: product %}
{%- endcomment -%}

{%- liquid
  assign featured_image = product.featured_image
  assign second_image    = product.images[1]
  assign on_sale         = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif
  assign sold_out = true
  if product.available
    assign sold_out = false
  endif
  assign show_vendor  = show_vendor | default: false
  assign show_rating  = show_rating | default: true
  assign product_url  = product.url | within: collection
-%}

<article
  class="card-product{% if sold_out %} card-product--sold-out{% endif %}"
  data-product-id="{{ product.id }}"
  aria-label="{{ product.title | escape }}"
>
  {%- comment -%} IMAGE ZONE {%- endcomment -%}
  <div class="card-product__media" aria-hidden="true">
    <a href="{{ product_url }}" class="card-product__image-link" tabindex="-1">
      {%- if featured_image != blank -%}
        <img
          class="card-product__img card-product__img--primary"
          src="{{ featured_image | image_url: width: 600 }}"
          alt="{{ featured_image.alt | default: product.title | escape }}"
          width="600"
          height="{{ 600 | divided_by: featured_image.aspect_ratio | round }}"
          loading="lazy"
          decoding="async"
        >
        {%- if second_image != blank -%}
          <img
            class="card-product__img card-product__img--secondary"
            src="{{ second_image | image_url: width: 600 }}"
            alt="{{ second_image.alt | default: product.title | escape }}"
            width="600"
            height="{{ 600 | divided_by: second_image.aspect_ratio | round }}"
            loading="lazy"
            decoding="async"
            aria-hidden="true"
          >
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'card-product__placeholder' }}
      {%- endif -%}
    </a>

    {%- comment -%} BADGES {%- endcomment -%}
    <div class="card-product__badges">
      {%- if on_sale -%}
        {%- assign savings = product.compare_at_price | minus: product.price -%}
        {%- assign pct = savings | times: 100 | divided_by: product.compare_at_price -%}
        <span class="badge badge--sale">-{{ pct }}%</span>
      {%- endif -%}
      {%- if sold_out -%}
        <span class="badge badge--sold-out">Epuise</span>
      {%- endif -%}
      {%- if product.tags contains 'bestseller' -%}
        <span class="badge badge--bestseller">Best-seller</span>
      {%- endif -%}
    </div>

    {%- comment -%} WISHLIST {%- endcomment -%}
    <button
      class="card-product__wishlist"
      aria-label="Ajouter {{ product.title | escape }} a ma liste de souhaits"
      data-wishlist-id="{{ product.id }}"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>
  </div>

  {%- comment -%} INFOS PRODUIT {%- endcomment -%}
  <div class="card-product__info">
    {%- if show_vendor and product.vendor != blank -%}
      <p class="card-product__vendor">{{ product.vendor }}</p>
    {%- endif -%}

    <h3 class="card-product__title">
      <a href="{{ product_url }}" class="card-product__title-link">
        {{- product.title | escape -}}
      </a>
    </h3>

    {%- comment -%} FLUX BADGE (metafield Octipa) {%- endcomment -%}
    {%- assign flux = product.metafields.custom.flux_level.value -%}
    {%- if flux != blank -%}
      <span class="card-product__flux-badge flux-badge--{{ flux | downcase | replace: ' ', '-' }}">
        {{- flux -}}
      </span>
    {%- endif -%}

    {%- comment -%} SWATCHES TAILLES {%- endcomment -%}
    {%- assign size_option = nil -%}
    {%- for option in product.options_with_values -%}
      {%- if option.name == 'Taille' or option.name == 'Size' -%}
        {%- assign size_option = option -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if size_option != nil -%}
      <div class="card-product__swatches" aria-label="Tailles disponibles" role="group">
        {%- for value in size_option.values -%}
          <span class="swatch swatch--size" aria-label="{{ value }}">{{ value }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} PRIX {%- endcomment -%}
    <div class="card-product__price-wrapper">
      {%- if on_sale -%}
        <s class="card-product__price--compare">
          <span class="sr-only">Ancien prix :</span>
          {{ product.compare_at_price | money }}
        </s>
      {%- endif -%}
      <span class="card-product__price{% if on_sale %} card-product__price--sale{% endif %}">
        {{ product.price | money }}
      </span>
    </div>

    {%- comment -%} QUICK ADD {%- endcomment -%}
    {%- if sold_out -%}
      <button class="card-product__atc btn btn--secondary" disabled>
        Epuise
      </button>
    {%- elsif product.variants.size == 1 -%}
      <button
        class="card-product__atc btn btn--primary"
        data-variant-id="{{ product.variants.first.id }}"
        data-quick-add
        aria-label="Ajouter {{ product.title | escape }} au panier"
      >
        <span class="card-product__atc-label">Ajouter au panier</span>
        <span class="card-product__atc-loading" aria-hidden="true">
          <svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/>
            <path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
          </svg>
        </span>
      </button>
    {%- else -%}
      <a href="{{ product_url }}" class="card-product__atc btn btn--primary">
        Voir les options
      </a>
    {%- endif -%}
  </div>
</article>

{% stylesheet %}
.card-product {
  --card-radius: 12px;
  --img-ratio: 4 / 5;
  display: flex;
  flex-direction: column;
  background: var(--color-surface, #fff);
  border-radius: var(--card-radius);
  overflow: hidden;
  box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 12px rgba(0,0,0,.04);
  transition: box-shadow 220ms ease, transform 220ms ease;
  position: relative;
}
.card-product:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,.10), 0 12px 32px rgba(0,0,0,.06);
  transform: translateY(-2px);
}
.card-product__media {
  position: relative;
  aspect-ratio: var(--img-ratio);
  overflow: hidden;
  background: #f3f0ec;
}
.card-product__image-link {
  display: block;
  width: 100%;
  height: 100%;
}
.card-product__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity 350ms ease, transform 400ms ease;
}
.card-product__img--primary {
  position: relative;
  z-index: 1;
}
.card-product__img--secondary {
  position: absolute;
  inset: 0;
  z-index: 2;
  opacity: 0;
}
.card-product__media:hover .card-product__img--secondary,
.card-product__media:focus-within .card-product__img--secondary {
  opacity: 1;
}
.card-product__media:hover .card-product__img--primary {
  transform: scale(1.03);
}
.card-product__placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.card-product__badges {
  position: absolute;
  top: 10px;
  left: 10px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  z-index: 3;
}
.badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 9px;
  border-radius: 999px;
  font-size: clamp(0.65rem, 0.6rem + 0.25vw, 0.75rem);
  font-weight: 600;
  line-height: 1.4;
  letter-spacing: .02em;
}
.badge--sale { background: #e63946; color: #fff; }
.badge--sold-out { background: #6b6b6b; color: #fff; }
.badge--bestseller { background: #f4e8c1; color: #7a5e00; }
.card-product__wishlist {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(255,255,255,.85);
  backdrop-filter: blur(6px);
  border: none;
  cursor: pointer;
  color: #c0c0c0;
  transition: color 200ms ease, background 200ms ease, transform 200ms ease;
}
.card-product__wishlist:hover,
.card-product__wishlist:focus-visible {
  color: #e63946;
  background: #fff;
  transform: scale(1.1);
}
.card-product__wishlist.is-wished { color: #e63946; }
.card-product__wishlist.is-wished svg { fill: #e63946; stroke: #e63946; }
.card-product__info {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 14px 16px 16px;
  flex: 1;
}
.card-product__vendor {
  font-size: clamp(0.7rem, 0.65rem + 0.2vw, 0.75rem);
  color: var(--color-text-muted, #7a7974);
  text-transform: uppercase;
  letter-spacing: .08em;
  margin: 0;
}
.card-product__title {
  margin: 0;
  font-size: clamp(0.9rem, 0.85rem + 0.25vw, 1.05rem);
  font-weight: 600;
  line-height: 1.35;
}
.card-product__title-link {
  color: var(--color-text, #28251d);
  text-decoration: none;
}
.card-product__title-link:hover {
  text-decoration: underline;
  text-underline-offset: 3px;
}
.card-product__flux-badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: .03em;
  width: fit-content;
}
.flux-badge--flux-modere { background: #dbeafe; color: #1e3a8a; }
.flux-badge--flux-eleve { background: #fef3c7; color: #92400e; }
.flux-badge--flux-tres-eleve { background: #fce7f3; color: #9d174d; }
.card-product__swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}
.swatch--size {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32px;
  height: 28px;
  padding: 0 8px;
  border-radius: 6px;
  border: 1px solid rgba(0,0,0,.15);
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--color-text, #28251d);
  background: var(--color-bg, #f7f6f2);
  cursor: pointer;
  transition: border-color 150ms ease, background 150ms ease;
}
.swatch--size:hover {
  border-color: var(--color-primary, #01696f);
  background: #cedcd8;
}
.card-product__price-wrapper {
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
}
.card-product__price {
  font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
  font-weight: 700;
  color: var(--color-text, #28251d);
}
.card-product__price--sale { color: #e63946; }
.card-product__price--compare {
  font-size: 0.85rem;
  color: var(--color-text-muted, #7a7974);
  text-decoration: line-through;
}
.card-product__atc {
  margin-top: auto;
  width: 100%;
  padding: 11px 16px;
  border-radius: 8px;
  font-size: clamp(0.875rem, 0.8rem + 0.35vw, 1rem);
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: background 200ms ease, transform 120ms ease, opacity 200ms ease;
  position: relative;
  overflow: hidden;
}
.btn--primary {
  background: var(--color-primary, #01696f);
  color: #fff;
}
.btn--primary:hover:not(:disabled) {
  background: var(--color-primary-hover, #0c4e54);
  transform: translateY(-1px);
}
.btn--primary:active:not(:disabled) { transform: translateY(0); }
.btn--secondary {
  background: var(--color-surface-offset, #f3f0ec);
  color: var(--color-text-muted, #7a7974);
}
.btn:disabled { opacity: .55; cursor: not-allowed; }
.card-product__atc[data-loading] .card-product__atc-label { opacity: 0; }
.card-product__atc:not([data-loading]) .card-product__atc-loading { display: none; }
.card-product__atc-loading {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
@keyframes spin { to { transform: rotate(360deg); } }
.spinner { animation: spin .8s linear infinite; }
.card-product--sold-out .card-product__media::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,.4);
  z-index: 1;
  pointer-events: none;
}
.sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0;
}
@media (min-width: 768px) {
  .card-product__info { padding: 16px 20px 20px; gap: 10px; }
}
{% endstylesheet %}

{% javascript %}
class QuickAddButton extends HTMLElement {
  constructor() {
    super();
    this._btn = this.querySelector('[data-quick-add]');
    if (this._btn) {
      this._btn.addEventListener('click', this._handleAdd.bind(this));
    }
  }
  async _handleAdd(e) {
    e.preventDefault();
    const btn = e.currentTarget;
    const variantId = btn.dataset.variantId;
    if (!variantId || btn.hasAttribute('data-loading')) return;
    btn.setAttribute('data-loading', '');
    btn.disabled = true;
    try {
      const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      });
      if (!response.ok) throw new Error('Erreur ajout panier');
      const item = await response.json();
      document.dispatchEvent(new CustomEvent('cart:add', { detail: { item } }));
      btn.removeAttribute('data-loading');
      const label = btn.querySelector('.card-product__atc-label');
      const originalText = label.textContent;
      label.textContent = 'Ajoute !';
      btn.style.background = '#437a22';
      setTimeout(() => {
        label.textContent = originalText;
        btn.style.background = '';
        btn.disabled = false;
      }, 2000);
    } catch (err) {
      console.error('[QuickAdd]', err);
      btn.removeAttribute('data-loading');
      btn.disabled = false;
    }
  }
}
if (!customElements.get('quick-add-button')) {
  customElements.define('quick-add-button', QuickAddButton);
}
class WishlistButton extends HTMLElement {
  connectedCallback() {
    this._btn = this.querySelector('[data-wishlist-id]');
    if (!this._btn) return;
    this._id = this._btn.dataset.wishlistId;
    this._update();
    this._btn.addEventListener('click', this._toggle.bind(this));
  }
  _getList() {
    try { return JSON.parse(localStorage.getItem('octipa_wishlist') || '[]'); }
    catch { return []; }
  }
  _saveList(list) {
    try { localStorage.setItem('octipa_wishlist', JSON.stringify(list)); } catch {}
  }
  _update() {
    const wished = this._getList().includes(this._id);
    this._btn.classList.toggle('is-wished', wished);
    this._btn.setAttribute('aria-pressed', wished.toString());
  }
  _toggle() {
    let list = this._getList();
    if (list.includes(this._id)) {
      list = list.filter(id => id !== this._id);
    } else {
      list.push(this._id);
    }
    this._saveList(list);
    this._update();
  }
}
if (!customElements.get('wishlist-button')) {
  customElements.define('wishlist-button', WishlistButton);
}
{% endjavascript %}
