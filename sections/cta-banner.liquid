{%- assign title_parts = section.settings.title | split: '**' -%}
<section class="cta-banner">
  <div class="container container--mid" style="text-align:center">
    <p class="section-eyebrow fade-up">{{ section.settings.eyebrow }}</p>
    <h2 class="section-title fade-up" style="color:#fff;transition-delay:80ms">
      {%- for p in title_parts -%}{%- if forloop.index0 == 1 -%}<em style="color:rgba(255,255,255,0.72)">{{ p }}</em>{%- else -%}{{ p }}{%- endif -%}{%- endfor -%}
    </h2>
    <p class="section-desc fade-up" style="color:rgba(255,255,255,0.85);margin-inline:auto;transition-delay:150ms">{{ section.settings.description }}</p>
    <div class="cta-actions fade-up" style="transition-delay:220ms">
      <a href="{{ section.settings.btn1_url }}" class="btn btn--white btn--lg">{{ section.settings.btn1_label }}</a>
      <a href="{{ section.settings.btn2_url }}" class="btn btn--outline-white btn--lg">{{ section.settings.btn2_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bannière CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Accroche", "default": "Prête à transformer votre peau ?" },
    { "type": "textarea", "id": "title", "label": "Titre (**italic**)", "default": "Commencez votre **ritual beauté**" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Rejoignez plus de 50 000 femmes qui ont adopté Octipa. Livraison offerte dès 49€." },
    { "type": "text", "id": "btn1_label", "label": "Bouton 1 (texte)", "default": "Découvrir la boutique" },
    { "type": "url", "id": "btn1_url", "label": "Bouton 1 (lien)", "default": "/collections/all" },
    { "type": "text", "id": "btn2_label", "label": "Bouton 2 (texte)", "default": "Faire le diagnostic" },
    { "type": "url", "id": "btn2_url", "label": "Bouton 2 (lien)", "default": "/pages/diagnostic" }
  ],
  "presets": [{ "name": "Bannière CTA" }]
}
{% endschema %}
