{%- comment -%}
  Section: hero
  Description: Section hero principale Octipa — image de fond, titre, sous-titre, CTA
  Schema: heading, subheading, cta_label, cta_url, image, overlay_opacity, text_align
{%- endcomment -%}

{%- liquid
  assign hero_image  = section.settings.image
  assign heading     = section.settings.heading | default: 'Reprenez confiance, au quotidien.'
  assign subheading  = section.settings.subheading | default: 'Sous-vetements anti-fuite discrets, confortables et elegants — concus pour vous.'
  assign cta_label   = section.settings.cta_label | default: 'Decouvrir la collection'
  assign cta_url     = section.settings.cta_url | default: '/collections/all'
  assign overlay     = section.settings.overlay_opacity | default: 40
  assign text_align  = section.settings.text_align | default: 'center'
-%}

<section
  class="hero hero--align-{{ text_align }}"
  aria-label="{{ heading | escape }}"
>
  <div class="hero__media">
    {%- if hero_image != blank -%}
      <img
        class="hero__img"
        src="{{ hero_image | image_url: width: 1800 }}"
        srcset="
          {{ hero_image | image_url: width: 750 }} 750w,
          {{ hero_image | image_url: width: 1100 }} 1100w,
          {{ hero_image | image_url: width: 1500 }} 1500w,
          {{ hero_image | image_url: width: 1800 }} 1800w
        "
        sizes="100vw"
        alt="{{ hero_image.alt | default: heading | escape }}"
        width="1800"
        height="{{ 1800 | divided_by: hero_image.aspect_ratio | round }}"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      >
    {%- else -%}
      <div class="hero__img-placeholder"></div>
    {%- endif -%}
    <div class="hero__overlay" style="--overlay-opacity: {{ overlay | divided_by: 100.0 }}"></div>
  </div>

  <div class="hero__content">
    <div class="hero__inner">
      <h1 class="hero__heading">{{ heading | escape }}</h1>
      {%- if subheading != blank -%}
        <p class="hero__subheading">{{ subheading | escape }}</p>
      {%- endif -%}
      {%- if cta_label != blank -%}
        <a href="{{ cta_url }}" class="hero__cta btn-hero">
          {{ cta_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
.hero {
  position: relative;
  width: 100%;
  min-height: 80vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: #1a1a1a;
}
.hero__media {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}
.hero__img-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #e8ddd0 0%, #c4b5a0 100%);
}
.hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,var(--overlay-opacity, 0.4));
  z-index: 1;
}
.hero__content {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: clamp(2rem, 6vw, 5rem) clamp(1rem, 5vw, 4rem);
}
.hero__inner {
  max-width: 760px;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.hero--align-center .hero__content { display: flex; justify-content: center; }
.hero--align-center .hero__inner { margin-inline: auto; align-items: center; text-align: center; }
.hero--align-left .hero__inner { margin-inline: 0; text-align: left; }
.hero__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.2rem, 2rem + 3vw, 5rem);
  font-weight: 500;
  line-height: 1.1;
  color: #ffffff;
  text-shadow: 0 2px 16px rgba(0,0,0,0.25);
  margin: 0;
  text-wrap: balance;
}
.hero__subheading {
  font-size: clamp(1rem, 0.9rem + 0.5vw, 1.25rem);
  font-weight: 400;
  color: rgba(255,255,255,0.88);
  max-width: 56ch;
  line-height: 1.6;
  margin: 0;
}
.btn-hero {
  display: inline-flex;
  align-items: center;
  padding: 14px 32px;
  background: #ffffff;
  color: #1a1a1a;
  font-size: 0.95rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  border-radius: 999px;
  text-decoration: none;
  border: 2px solid transparent;
  transition: background 200ms ease, color 200ms ease, transform 150ms ease;
  margin-top: 0.5rem;
  width: fit-content;
}
.btn-hero:hover {
  background: transparent;
  color: #ffffff;
  border-color: #ffffff;
  transform: translateY(-2px);
}
.btn-hero:active { transform: translateY(0); }
@media (min-width: 768px) { .hero { min-height: 85vh; } }
@media (min-width: 1024px) { .hero { min-height: 90vh; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacite du voile sombre",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre principal",
      "default": "Reprenez confiance, au quotidien."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Sous-vetements anti-fuite discrets, confortables et elegants — concus pour vous."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte du bouton",
      "default": "Decouvrir la collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien du bouton"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alignement du texte",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centre" }
      ],
      "default": "center"
    }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
