<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ page_description | escape }}">
  <title>{{ page_title }}{% unless page_title contains shop.name %} &mdash; {{ shop.name }}{% endunless %}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Satoshi:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body>
  <a class="sr-only" href="#MainContent">Aller au contenu</a>
  {%- section 'header' -%}
  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>
  {%- section 'footer' -%}
  {%- render 'cart-drawer' -%}
  {%- render 'mobile-nav' -%}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
