{%- comment -%}
  Section: collection-banner
  Description: Bandeau haut de page collection — titre, description, image de fond
{%- endcomment -%}

{%- liquid
  assign banner_image = section.settings.banner_image | default: collection.image
  assign show_desc    = section.settings.show_description
-%}

<div class="collection-banner{% if banner_image %} collection-banner--has-image{% endif %}">
  {%- if banner_image -%}
    <img
      class="collection-banner__bg"
      src="{{ banner_image | image_url: width: 1400 }}"
      alt="{{ collection.title | escape }}"
      width="1400"
      height="400"
      loading="eager"
      decoding="async"
    >
    <div class="collection-banner__overlay"></div>
  {%- endif -%}
  <div class="collection-banner__content container">
    <h1 class="collection-banner__title">{{ collection.title }}</h1>
    {%- if show_desc and collection.description != blank -%}
      <p class="collection-banner__desc">{{ collection.description }}</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.collection-banner {
  position: relative;
  background: var(--color-primary-highlight, #cedcd8);
  padding-block: clamp(2rem, 4vw, 3.5rem);
  overflow: hidden;
  text-align: center;
}

.collection-banner__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}

.collection-banner__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.42);
  z-index: 1;
}

.collection-banner__content {
  position: relative;
  z-index: 2;
}

.collection-banner__title {
  font-family: var(--font-display, Georgia, serif);
  font-size: clamp(1.8rem, 1rem + 3vw, 3rem);
  font-weight: 700;
  line-height: 1.15;
  color: var(--color-text, #28251d);
}

.collection-banner--has-image .collection-banner__title {
  color: #fff;
}

.collection-banner__desc {
  margin-top: .75rem;
  font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1.05rem);
  color: var(--color-text-muted, #7a7974);
  max-width: 60ch;
  margin-inline: auto;
  line-height: 1.65;
}

.collection-banner--has-image .collection-banner__desc {
  color: rgba(255,255,255,.85);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Bandeau collection",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Image de fond (optionnel)",
      "info": "Laissez vide pour utiliser l'image de la collection"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Afficher la description",
      "default": true
    }
  ],
  "presets": [{"name": "Bandeau collection"}]
}
{% endschema %}
