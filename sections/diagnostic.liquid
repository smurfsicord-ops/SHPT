{%- comment -%}
  Section: diagnostic
  Diagnostic personnalisé Octipa — quiz autonome avec recommandation finale
{%- endcomment -%}

<section class="octi-diagnostic" id="octi-diagnostic">
  <div class="octi-diagnostic__container page-width">
    <div class="octi-diagnostic__intro" id="diag-intro">
      <span class="octi-diagnostic__kicker">Diagnostic personnalisé</span>
      <h1 class="octi-diagnostic__title">Trouvez la culotte <em>faite pour vous</em></h1>
      <p class="octi-diagnostic__lead">Répondez à 5 questions et découvrez en moins de 2 minutes le modèle Octipa le plus adapté à votre quotidien, votre niveau de flux et vos priorités.</p>
      <div class="octi-diagnostic__intro-points">
        <span>✓ 100% gratuit</span>
        <span>✓ Rapide</span>
        <span>✓ Recommandation claire</span>
      </div>
      <button class="octi-diagnostic__cta" type="button" onclick="octiDiag.start()">Commencer le diagnostic</button>
    </div>

    <div class="octi-diagnostic__quiz is-hidden" id="diag-quiz">
      <div class="octi-diagnostic__topbar">
        <p class="octi-diagnostic__step" id="diag-step-text">Question 1 sur 5</p>
        <div class="octi-diagnostic__progress">
          <div class="octi-diagnostic__progress-bar" id="diag-progress-bar" style="width: 20%;"></div>
        </div>
      </div>

      <div class="octi-question" data-question="0">
        <h2 class="octi-question__title">Dans quelle situation porterez-vous surtout votre culotte anti-fuite ?</h2>
        <div class="octi-question__answers">
          <button type="button" onclick="octiDiag.answer('usage','daily')">Au quotidien</button>
          <button type="button" onclick="octiDiag.answer('usage','night')">La nuit</button>
          <button type="button" onclick="octiDiag.answer('usage','sport')">Pendant le sport</button>
          <button type="button" onclick="octiDiag.answer('usage','mixed')">Un peu pour tout</button>
        </div>
      </div>

      <div class="octi-question is-hidden" data-question="1">
        <h2 class="octi-question__title">Quel niveau de protection recherchez-vous ?</h2>
        <div class="octi-question__answers">
          <button type="button" onclick="octiDiag.answer('flow','light')">Léger</button>
          <button type="button" onclick="octiDiag.answer('flow','medium')">Modéré</button>
          <button type="button" onclick="octiDiag.answer('flow','heavy')">Élevé</button>
          <button type="button" onclick="octiDiag.answer('flow','variable')">Variable selon les jours</button>
        </div>
      </div>

      <div class="octi-question is-hidden" data-question="2">
        <h2 class="octi-question__title">Quelle qualité compte le plus pour vous ?</h2>
        <div class="octi-question__answers">
          <button type="button" onclick="octiDiag.answer('priority','comfort')">Le confort</button>
          <button type="button" onclick="octiDiag.answer('priority','discreet')">La discrétion</button>
          <button type="button" onclick="octiDiag.answer('priority','security')">La sécurité maximale</button>
          <button type="button" onclick="octiDiag.answer('priority','style')">Le style</button>
        </div>
      </div>

      <div class="octi-question is-hidden" data-question="3">
        <h2 class="octi-question__title">Quel type de matière préférez-vous ?</h2>
        <div class="octi-question__answers">
          <button type="button" onclick="octiDiag.answer('fabric','cotton')">Coton doux</button>
          <button type="button" onclick="octiDiag.answer('fabric','technical')">Matière technique</button>
          <button type="button" onclick="octiDiag.answer('fabric','soft')">Très douce et souple</button>
          <button type="button" onclick="octiDiag.answer('fabric','no_pref')">Pas de préférence</button>
        </div>
      </div>

      <div class="octi-question is-hidden" data-question="4">
        <h2 class="octi-question__title">Vous souhaitez plutôt commencer comment ?</h2>
        <div class="octi-question__answers">
          <button type="button" onclick="octiDiag.answer('start','single')">Avec un premier modèle</button>
          <button type="button" onclick="octiDiag.answer('start','pack')">Avec un pack</button>
          <button type="button" onclick="octiDiag.answer('start','best')">Avec la meilleure recommandation</button>
          <button type="button" onclick="octiDiag.answer('start','compare')">En comparant plusieurs options</button>
        </div>
      </div>
    </div>

    <div class="octi-diagnostic__result is-hidden" id="diag-result"></div>
  </div>
</section>

<style>
.octi-diagnostic {
  background: #f8f4ef;
  padding: 56px 20px 80px;
}
.octi-diagnostic__container {
  max-width: 860px;
  margin: 0 auto;
}
.octi-diagnostic__intro,
.octi-diagnostic__quiz,
.octi-diagnostic__result {
  background: #fff;
  border: 1px solid #eadfd4;
  border-radius: 24px;
  padding: 36px;
  box-shadow: 0 10px 30px rgba(53, 32, 21, 0.05);
}
.octi-diagnostic__kicker {
  display: inline-block;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .14em;
  color: #a06f5d;
  margin-bottom: 12px;
}
.octi-diagnostic__title {
  font-size: clamp(34px, 5vw, 54px);
  line-height: 1.02;
  color: #24160f;
  margin: 0 0 16px;
}
.octi-diagnostic__title em {
  font-style: italic;
  color: #b7806e;
}
.octi-diagnostic__lead {
  max-width: 650px;
  color: #6e5d55;
  font-size: 17px;
  line-height: 1.7;
  margin: 0 0 24px;
}
.octi-diagnostic__intro-points {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 28px;
  color: #4f3b31;
  font-size: 14px;
  font-weight: 600;
}
.octi-diagnostic__cta,
.octi-question__answers button,
.octi-result__actions a,
.octi-result__actions button {
  cursor: pointer;
  border: 0;
  border-radius: 14px;
  transition: all .2s ease;
}
.octi-diagnostic__cta {
  background: #24160f;
  color: #fff;
  padding: 16px 24px;
  font-size: 16px;
  font-weight: 700;
}
.octi-diagnostic__cta:hover {
  background: #3a2419;
  transform: translateY(-1px);
}
.octi-diagnostic__topbar {
  margin-bottom: 28px;
}
.octi-diagnostic__step {
  margin: 0 0 10px;
  font-size: 13px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #8c776d;
  font-weight: 700;
}
.octi-diagnostic__progress {
  width: 100%;
  height: 10px;
  background: #f1e8e0;
  border-radius: 999px;
  overflow: hidden;
}
.octi-diagnostic__progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #b7806e 0%, #24160f 100%);
  border-radius: 999px;
}
.octi-question__title {
  font-size: clamp(24px, 3vw, 34px);
  line-height: 1.2;
  color: #24160f;
  margin: 0 0 22px;
}
.octi-question__answers {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.octi-question__answers button {
  background: #fcfaf8;
  border: 1px solid #eadfd4;
  padding: 18px 18px;
  text-align: left;
  font-size: 16px;
  font-weight: 600;
  color: #34231c;
}
.octi-question__answers button:hover {
  border-color: #b7806e;
  background: #fff4ef;
  transform: translateY(-1px);
}
.octi-result__tag {
  display: inline-block;
  margin-bottom: 14px;
  padding: 8px 12px;
  border-radius: 999px;
  background: #f7ede7;
  color: #9b6d5d;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
}
.octi-result__title {
  font-size: clamp(30px, 4vw, 46px);
  line-height: 1.08;
  margin: 0 0 12px;
  color: #24160f;
}
.octi-result__text {
  font-size: 17px;
  line-height: 1.75;
  color: #6e5d55;
  margin: 0 0 22px;
}
.octi-result__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 24px;
}
.octi-result__chips span {
  padding: 9px 12px;
  border-radius: 999px;
  background: #fcf6f2;
  border: 1px solid #eadfd4;
  font-size: 13px;
  font-weight: 700;
  color: #5e463b;
}
.octi-result__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
.octi-result__actions a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 15px 20px;
  background: #24160f;
  color: #fff;
  text-decoration: none;
  font-weight: 700;
}
.octi-result__actions a:hover {
  background: #3a2419;
}
.octi-result__actions button {
  padding: 15px 20px;
  background: #fff;
  border: 1px solid #d9c9bf;
  color: #24160f;
  font-weight: 700;
}
.octi-result__actions button:hover {
  background: #f8f4ef;
}
.is-hidden { display: none; }
@media screen and (max-width: 749px) {
  .octi-diagnostic {
    padding: 32px 16px 52px;
  }
  .octi-diagnostic__intro,
  .octi-diagnostic__quiz,
  .octi-diagnostic__result {
    padding: 24px;
    border-radius: 18px;
  }
  .octi-question__answers {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
window.octiDiag = {
  current: 0,
  total: 5,
  answers: {},
  results: {
    comfort: {
      tag: 'Votre diagnostic Octipa',
      title: 'Le modèle Confort Quotidien semble fait pour vous',
      text: 'Vous recherchez avant tout une culotte rassurante, agréable à porter et facile à intégrer dans votre routine. Nous vous recommandons un modèle polyvalent, doux et discret, parfait pour un usage régulier.',
      chips: ['Confort longue durée', 'Usage quotidien', 'Discret sous les vêtements', 'Protection équilibrée'],
      cta: '/collections/all'
    },
    night: {
      tag: 'Votre diagnostic Octipa',
      title: 'Votre priorité est une protection nuit renforcée',
      text: 'Vous avez besoin d\'une culotte à absorption élevée, capable de rester fiable pendant plusieurs heures. Le meilleur choix pour vous est un modèle pensé pour la nuit ou les flux plus intenses.',
      chips: ['Protection renforcée', 'Idéal la nuit', 'Flux élevé', 'Sensation de sécurité'],
      cta: '/collections/all'
    },
    sport: {
      tag: 'Votre diagnostic Octipa',
      title: 'Un modèle actif et technique vous conviendra le mieux',
      text: 'Comme vous cherchez une culotte à porter pendant vos mouvements, votre recommandation idéale est un modèle stable, respirant et pensé pour accompagner votre rythme sans gêne.',
      chips: ['Matière technique', 'Bonne tenue', 'Respirant', 'Parfait pour bouger'],
      cta: '/collections/all'
    },
    pack: {
      tag: 'Votre diagnostic Octipa',
      title: 'Commencer avec un pack est la meilleure option pour vous',
      text: 'Vous avez intérêt à comparer plusieurs sensations d\'usage. Un pack vous permet de tester plusieurs niveaux ou plusieurs formes pour trouver rapidement votre routine idéale.',
      chips: ['Découverte facile', 'Plusieurs options', 'Bon rapport qualité-prix', 'Idéal pour débuter'],
      cta: '/collections/all'
    },
    elegant: {
      tag: 'Votre diagnostic Octipa',
      title: 'Vous allez aimer un modèle discret, élégant et féminin',
      text: 'Votre priorité va vers la discrétion et le style. Le modèle le plus adapté pour vous est une culotte fine, raffinée et agréable à porter sous vos vêtements de tous les jours.',
      chips: ['Discrétion', 'Style soigné', 'Confort souple', 'Usage urbain'],
      cta: '/collections/all'
    }
  },
  start() {
    document.getElementById('diag-intro').classList.add('is-hidden');
    document.getElementById('diag-result').classList.add('is-hidden');
    document.getElementById('diag-quiz').classList.remove('is-hidden');
    this.current = 0;
    this.answers = {};
    this.render();
  },
  answer(key, value) {
    this.answers[key] = value;
    this.current++;
    if (this.current >= this.total) {
      this.showResult();
      return;
    }
    this.render();
  },
  render() {
    var questions = document.querySelectorAll('.octi-question');
    questions.forEach(function(el, index) {
      el.classList.toggle('is-hidden', index !== octiDiag.current);
    });
    document.getElementById('diag-step-text').textContent = 'Question ' + (this.current + 1) + ' sur 5';
    document.getElementById('diag-progress-bar').style.width = ((this.current + 1) / this.total * 100) + '%';
  },
  showResult() {
    document.getElementById('diag-quiz').classList.add('is-hidden');
    var resultKey = this.compute();
    var result = this.results[resultKey];
    var html = '' +
      '<div class="octi-result__tag">' + result.tag + '</div>' +
      '<h2 class="octi-result__title">' + result.title + '</h2>' +
      '<p class="octi-result__text">' + result.text + '</p>' +
      '<div class="octi-result__chips">' + result.chips.map(function(item){ return '<span>' + item + '</span>'; }).join('') + '</div>' +
      '<div class="octi-result__actions">' +
        '<a href="' + result.cta + '">Voir la recommandation</a>' +
        '<button type="button" onclick="octiDiag.restart()">Recommencer</button>' +
      '</div>';
    var resultNode = document.getElementById('diag-result');
    resultNode.innerHTML = html;
    resultNode.classList.remove('is-hidden');
  },
  compute() {
    if (this.answers.usage === 'night' || this.answers.flow === 'heavy') return 'night';
    if (this.answers.usage === 'sport' || this.answers.fabric === 'technical') return 'sport';
    if (this.answers.start === 'pack' || this.answers.start === 'compare') return 'pack';
    if (this.answers.priority === 'style' || this.answers.priority === 'discreet') return 'elegant';
    return 'comfort';
  },
  restart() {
    this.start();
  }
};
</script>

{% schema %}
{
  "name": "Diagnostic",
  "settings": [],
  "presets": [
    {
      "name": "Diagnostic"
    }
  ]
}
{% endschema %}
