{%- comment -%}
  Section: footer
  Description: Pied de page Octipa — 4 colonnes, réseaux, paiement
{%- endcomment -%}

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">

      <div class="footer-col footer-col--brand">
        <div class="footer-brand">{{ section.settings.brand_name | default: 'Octipa' }}</div>
        <p class="footer-desc">{{ section.settings.description }}</p>
        <div class="footer-socials">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" class="footer-social" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok != blank -%}
            <a href="{{ section.settings.tiktok }}" class="footer-social" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.72a8.17 8.17 0 004.78 1.52V6.82a4.85 4.85 0 01-1.01-.13z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.pinterest != blank -%}
            <a href="{{ section.settings.pinterest }}" class="footer-social" aria-label="Pinterest" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">Boutique</div>
        <div class="footer-links">
          <a href="{{ routes.all_products_collection_url }}">Tous les produits</a>
          <a href="{{ routes.collections_url }}">Collections</a>
          <a href="/collections/packs">Nos packs</a>
          <a href="/pages/diagnostic">Diagnostic flux</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">À propos</div>
        <div class="footer-links">
          <a href="/pages/about">Notre histoire</a>
          <a href="/pages/engagements">Nos engagements</a>
          <a href="/blogs/news">Le journal</a>
          <a href="/pages/contact">Contact</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">Aide</div>
        <div class="footer-links">
          <a href="/pages/livraison">Livraison &amp; retours</a>
          <a href="/pages/faq">FAQ</a>
          <a href="{{ routes.root_url }}policies/privacy-policy">Confidentialité</a>
          <a href="{{ routes.root_url }}policies/terms-of-service">CGV</a>
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <p class="footer-copy">{{ section.settings.copyright | default: '\u00a9 2025 Octipa. Tous droits r\u00e9serv\u00e9s.' }}</p>
      <div class="payment-icons">
        <span class="payment-icon">VISA</span>
        <span class="payment-icon">MC</span>
        <span class="payment-icon">AMEX</span>
        <span class="payment-icon">PayPal</span>
        <span class="payment-icon">Apple Pay</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Pied de page",
  "settings": [
    { "type": "text",     "id": "brand_name",  "label": "Nom de la marque",  "default": "Octipa" },
    { "type": "textarea","id": "description", "label": "Description courte", "default": "Discr\u00e9tion, confort et confiance au quotidien." },
    { "type": "url",     "id": "instagram",   "label": "Instagram" },
    { "type": "url",     "id": "tiktok",      "label": "TikTok" },
    { "type": "url",     "id": "pinterest",   "label": "Pinterest" },
    { "type": "text",    "id": "copyright",   "label": "Copyright", "default": "\u00a9 2025 Octipa. Tous droits r\u00e9serv\u00e9s." }
  ]
}
{% endschema %}
