{%- assign title_parts = section.settings.title | split: '**' -%}
<section class="hero">
  <div class="hero-content">
    <p class="hero-eyebrow fade-up">{{ section.settings.eyebrow }}</p>
    <h1 class="hero-title fade-up" style="transition-delay:100ms">
      {%- for p in title_parts -%}{%- if forloop.index0 == 1 -%}<em>{{ p }}</em>{%- else -%}{{ p }}{%- endif -%}{%- endfor -%}
    </h1>
    <p class="hero-desc fade-up" style="transition-delay:200ms">{{ section.settings.description }}</p>
    <div class="hero-actions fade-up" style="transition-delay:250ms">
      <a href="{{ section.settings.btn1_url }}" class="btn btn--primary btn--lg">{{ section.settings.btn1_label }}</a>
      <a href="{{ section.settings.btn2_url }}" class="btn btn--outline btn--lg">{{ section.settings.btn2_label }}</a>
    </div>
    <div class="hero-stats fade-up" style="transition-delay:300ms">
      <div class="hero-stat">
        <span class="hero-stat-number">{{ section.settings.stat1_num }}</span>
        <span class="hero-stat-label">{{ section.settings.stat1_label }}</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-number">{{ section.settings.stat2_num }}</span>
        <span class="hero-stat-label">{{ section.settings.stat2_label }}</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-number">{{ section.settings.stat3_num }}</span>
        <span class="hero-stat-label">{{ section.settings.stat3_label }}</span>
      </div>
    </div>
  </div>
  <div class="hero-image">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | img_url: '900x1200', crop: 'center' | img_tag: section.settings.eyebrow, 'loading="eager" width="900" height="1200"' }}
    {%- else -%}
      <img src="{{ 'hero-main.jpg' | asset_url }}" alt="Octipa" width="900" height="1200" loading="eager">
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Accroche", "default": "Soin naturel premium" },
    { "type": "textarea", "id": "title", "label": "Titre (* * pour italique coloré)", "default": "La nature au service de votre **beauté**" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Des soins formulés avec les actifs les plus purs, pour révéler l'éclat naturel de votre peau chaque jour." },
    { "type": "text", "id": "btn1_label", "label": "Bouton principal (texte)", "default": "Découvrir la gamme" },
    { "type": "url", "id": "btn1_url", "label": "Bouton principal (lien)", "default": "/collections/all" },
    { "type": "text", "id": "btn2_label", "label": "Bouton secondaire (texte)", "default": "Notre histoire" },
    { "type": "url", "id": "btn2_url", "label": "Bouton secondaire (lien)", "default": "/pages/about" },
    { "type": "image_picker", "id": "image", "label": "Image (colonne droite)" },
    { "type": "text", "id": "stat1_num", "label": "Stat 1 — chiffre", "default": "98%" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 — libellé", "default": "Ingrédients naturels" },
    { "type": "text", "id": "stat2_num", "label": "Stat 2 — chiffre", "default": "50k+" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 — libellé", "default": "Clientes satisfaites" },
    { "type": "text", "id": "stat3_num", "label": "Stat 3 — chiffre", "default": "4.9★" },
    { "type": "text", "id": "stat3_label", "label": "Stat 3 — libellé", "default": "Note moyenne" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
