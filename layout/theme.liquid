<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ page_description | escape }}">
  <title>{{ page_title }}{% unless page_title contains shop.name %} &mdash; {{ shop.name }}{% endunless %}</title>

  {%- comment -%} Fonts {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">

  {%- comment -%} CSS {%- endcomment -%}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>
<body>
  <a class="sr-only" href="#MainContent">Aller au contenu</a>
  {%- section 'header' -%}
  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>
  {%- section 'footer' -%}
  {%- render 'cart-drawer' -%}
  {%- render 'mobile-nav' -%}
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
