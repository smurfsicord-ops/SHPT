{%- comment -%}
  Section: contact-form
  Description: Formulaire de contact Octipa — nom, email, sujet, message
  Schema: heading, subheading, show_info
{%- endcomment -%}

{%- liquid
  assign heading    = section.settings.heading    | default: 'Contactez-nous'
  assign subheading = section.settings.subheading | default: 'Une question sur votre commande, un conseil produit ? Notre équipe vous répond sous 24h.'
  assign show_info  = section.settings.show_info
  assign email      = section.settings.contact_email | default: shop.email
  assign phone      = section.settings.contact_phone
  assign hours      = section.settings.contact_hours | default: 'Lundi – Vendredi, 9h – 18h'
-%}

<section class="contact-section" id="contact">
  <div class="contact-section__container">

    {%- comment -%} EN-TÊTE {%- endcomment -%}
    <div class="contact-section__header">
      <p class="contact-section__eyebrow">Support client</p>
      <h1 class="contact-section__heading">{{ heading }}</h1>
      <p class="contact-section__subheading">{{ subheading }}</p>
    </div>

    <div class="contact-section__body">

      {%- comment -%} FORMULAIRE {%- endcomment -%}
      <div class="contact-form-wrap">

        {%- form 'contact', id: 'ContactForm', class: 'contact-form' -%}

          {%- if form.posted_successfully? -%}
            <div class="contact-form__success" role="alert">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
              <div>
                <strong>Message envoyé !</strong>
                <p>Nous vous répondrons dans les plus brefs délais.</p>
              </div>
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="contact-form__error" role="alert">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <p>{{ form.errors | default_errors }}</p>
            </div>
          {%- endif -%}

          <div class="contact-form__row">
            <div class="form-field">
              <label for="ContactFormName" class="form-field__label">Prénom et nom <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="ContactFormName"
                name="contact[name]"
                class="form-field__input"
                value="{%- if form.name -%}{{ form.name }}{%- elsif customer -%}{{ customer.name }}{%- endif -%}"
                autocomplete="name"
                required
                placeholder="Marie Dupont"
                aria-required="true"
              >
            </div>

            <div class="form-field">
              <label for="ContactFormEmail" class="form-field__label">Adresse e-mail <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="ContactFormEmail"
                name="contact[email]"
                class="form-field__input"
                value="{%- if form.email -%}{{ form.email }}{%- elsif customer -%}{{ customer.email }}{%- endif -%}"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                required
                placeholder="marie@exemple.fr"
                aria-required="true"
              >
            </div>
          </div>

          <div class="form-field">
            <label for="ContactFormSubject" class="form-field__label">Sujet</label>
            <div class="form-field__select-wrap">
              <select id="ContactFormSubject" name="contact[subject]" class="form-field__select">
                <option value="">Choisir un sujet…</option>
                <option value="Commande en cours">Commande en cours</option>
                <option value="Retour / Échange">Retour / Échange</option>
                <option value="Conseil produit">Conseil produit</option>
                <option value="Guide des tailles">Guide des tailles</option>
                <option value="Paiement">Paiement</option>
                <option value="Autre">Autre</option>
              </select>
              <svg class="form-field__select-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </div>
          </div>

          <div class="form-field">
            <label for="ContactFormMessage" class="form-field__label">Votre message <span aria-hidden="true">*</span></label>
            <textarea
              id="ContactFormMessage"
              name="contact[body]"
              class="form-field__input form-field__textarea"
              rows="6"
              required
              placeholder="Décrivez votre demande en détail…"
              aria-required="true"
            >{{- form.body -}}</textarea>
          </div>

          <button type="submit" class="btn btn--primary btn--full contact-form__submit">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Envoyer le message
          </button>

        {%- endform -%}
      </div>

      {%- comment -%} INFOS CONTACT {%- endcomment -%}
      {%- if show_info -%}
      <aside class="contact-info">
        <div class="contact-info__card">
          <div class="contact-info__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <p class="contact-info__label">E-mail</p>
            <a href="mailto:{{ email }}" class="contact-info__value">{{ email }}</a>
          </div>
        </div>

        {%- if phone != blank -%}
        <div class="contact-info__card">
          <div class="contact-info__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6.16 6.16l.99-.99a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <p class="contact-info__label">Téléphone</p>
            <a href="tel:{{ phone | remove: ' ' }}" class="contact-info__value">{{ phone }}</a>
          </div>
        </div>
        {%- endif -%}

        <div class="contact-info__card">
          <div class="contact-info__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <p class="contact-info__label">Horaires</p>
            <p class="contact-info__value">{{ hours }}</p>
          </div>
        </div>

        <div class="contact-info__reassurance">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p>Vos données sont protégées et ne sont jamais partagées avec des tiers.</p>
        </div>
      </aside>
      {%- endif -%}

    </div>
  </div>
</section>

{% stylesheet %}
/* ============================================================
   CONTACT FORM — Octipa
   ============================================================ */

.contact-section {
  padding-block: clamp(3rem, 6vw, 6rem);
  background: var(--color-bg, #f7f6f2);
}

.contact-section__container {
  max-width: 1100px;
  margin-inline: auto;
  padding-inline: clamp(1rem, 4vw, 2rem);
}

/* HEADER */
.contact-section__header {
  text-align: center;
  margin-bottom: clamp(2rem, 4vw, 3.5rem);
}

.contact-section__eyebrow {
  font-size: clamp(0.7rem, 0.65rem + 0.2vw, 0.8rem);
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--color-primary, #01696f);
  margin-bottom: 0.75rem;
}

.contact-section__heading {
  font-family: var(--font-display, Georgia, serif);
  font-size: clamp(1.8rem, 1.2rem + 2.5vw, 3rem);
  font-weight: 700;
  color: var(--color-text, #28251d);
  line-height: 1.15;
  margin-bottom: 1rem;
}

.contact-section__subheading {
  font-size: clamp(0.95rem, 0.9rem + 0.2vw, 1.1rem);
  color: var(--color-text-muted, #7a7974);
  max-width: 52ch;
  margin-inline: auto;
  line-height: 1.65;
}

/* BODY LAYOUT */
.contact-section__body {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
}

@media (min-width: 900px) {
  .contact-section__body {
    grid-template-columns: 1fr 340px;
    align-items: start;
    gap: 3rem;
  }
}

/* FORM WRAP */
.contact-form-wrap {
  background: #fff;
  border-radius: 16px;
  padding: clamp(1.5rem, 4vw, 2.5rem);
  box-shadow: 0 2px 8px rgba(0,0,0,.06), 0 8px 24px rgba(0,0,0,.04);
}

/* FORM */
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.contact-form__row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
}

@media (min-width: 600px) {
  .contact-form__row { grid-template-columns: 1fr 1fr; }
}

/* FORM FIELD */
.form-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-field__label {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--color-text, #28251d);
  letter-spacing: .01em;
}

.form-field__label span {
  color: var(--color-primary, #01696f);
  margin-left: 2px;
}

.form-field__input {
  width: 100%;
  padding: 11px 14px;
  font-size: 0.95rem;
  color: var(--color-text, #28251d);
  background: var(--color-bg, #f7f6f2);
  border: 1.5px solid #ddd;
  border-radius: 10px;
  outline: none;
  transition: border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
  font-family: inherit;
}

.form-field__input::placeholder {
  color: #bab9b4;
}

.form-field__input:hover {
  border-color: #c0c0c0;
}

.form-field__input:focus {
  border-color: var(--color-primary, #01696f);
  background: #fff;
  box-shadow: 0 0 0 3px rgba(1, 105, 111, 0.12);
}

.form-field__textarea {
  resize: vertical;
  min-height: 140px;
  line-height: 1.6;
}

/* SELECT */
.form-field__select-wrap {
  position: relative;
}

.form-field__select {
  width: 100%;
  padding: 11px 40px 11px 14px;
  font-size: 0.95rem;
  color: var(--color-text, #28251d);
  background: var(--color-bg, #f7f6f2);
  border: 1.5px solid #ddd;
  border-radius: 10px;
  outline: none;
  appearance: none;
  cursor: pointer;
  font-family: inherit;
  transition: border-color 180ms ease, box-shadow 180ms ease;
}

.form-field__select:focus {
  border-color: var(--color-primary, #01696f);
  box-shadow: 0 0 0 3px rgba(1, 105, 111, 0.12);
}

.form-field__select-icon {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  color: #7a7974;
}

/* SUBMIT */
.contact-form__submit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 14px 24px;
  background: var(--color-primary, #01696f);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 200ms ease, transform 120ms ease;
  margin-top: 0.5rem;
}

.contact-form__submit:hover {
  background: var(--color-primary-hover, #0c4e54);
  transform: translateY(-1px);
}

.contact-form__submit:active {
  transform: translateY(0);
}

.btn--full { width: 100%; }

/* SUCCESS / ERROR */
.contact-form__success {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px;
  background: #d4dfcc;
  border-radius: 10px;
  color: #1e3f0a;
  font-size: 0.92rem;
  margin-bottom: 0.5rem;
}

.contact-form__success strong {
  display: block;
  font-size: 1rem;
  margin-bottom: 2px;
}

.contact-form__error {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px;
  background: #fce7f3;
  border-radius: 10px;
  color: #9d174d;
  font-size: 0.92rem;
  margin-bottom: 0.5rem;
}

/* INFO SIDEBAR */
.contact-info {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.contact-info__card {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  background: #fff;
  border-radius: 12px;
  padding: 18px;
  box-shadow: 0 1px 4px rgba(0,0,0,.06);
}

.contact-info__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  flex-shrink: 0;
  background: var(--color-primary-highlight, #cedcd8);
  border-radius: 10px;
  color: var(--color-primary, #01696f);
}

.contact-info__label {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--color-text-muted, #7a7974);
  margin-bottom: 4px;
}

.contact-info__value {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-text, #28251d);
  text-decoration: none;
  line-height: 1.4;
}

a.contact-info__value:hover {
  color: var(--color-primary, #01696f);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.contact-info__reassurance {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 14px 16px;
  background: #f0f7f7;
  border-radius: 10px;
  border: 1px solid #cedcdc;
  font-size: 0.8rem;
  color: #01696f;
  line-height: 1.5;
}

.contact-info__reassurance p { max-width: 100%; margin: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "Formulaire de contact",
  "tag": "section",
  "class": "section-contact",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Contactez-nous"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Une question sur votre commande, un conseil produit ? Notre équipe vous répond sous 24h."
    },
    {
      "type": "checkbox",
      "id": "show_info",
      "label": "Afficher les infos de contact",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "E-mail de contact",
      "info": "Laissez vide pour utiliser l'email de la boutique"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Téléphone (optionnel)"
    },
    {
      "type": "text",
      "id": "contact_hours",
      "label": "Horaires d'ouverture",
      "default": "Lundi – Vendredi, 9h – 18h"
    }
  ],
  "presets": [
    {
      "name": "Formulaire de contact"
    }
  ]
}
{% endschema %}
