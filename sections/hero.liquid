{%- comment -%}
  Section: hero
  Description: Hero principal homepage Octipa — sous-vêtements anti-fuite
  Schema: eyebrow, title, description, btn1, btn2, stats, image
{%- endcomment -%}

{%- liquid
  assign eyebrow     = section.settings.eyebrow
  assign title_parts = section.settings.title | split: '**'
  assign description = section.settings.description
  assign btn1_label  = section.settings.btn1_label
  assign btn1_url    = section.settings.btn1_url
  assign btn2_label  = section.settings.btn2_label
  assign btn2_url    = section.settings.btn2_url
-%}

<section class="hero" aria-label="{{ eyebrow | escape }}">
  <div class="hero__inner container">

    <div class="hero__content">
      {%- if eyebrow != blank -%}
        <p class="hero__eyebrow">{{ eyebrow }}</p>
      {%- endif -%}

      <h1 class="hero__title">
        {%- for part in title_parts -%}
          {%- if forloop.index0 == 1 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
        {%- endfor -%}
      </h1>

      {%- if description != blank -%}
        <p class="hero__desc">{{ description }}</p>
      {%- endif -%}

      <div class="hero__actions">
        {%- if btn1_label != blank -%}
          <a href="{{ btn1_url | default: '/collections/all' }}" class="btn btn--primary btn--lg">{{ btn1_label }}</a>
        {%- endif -%}
        {%- if btn2_label != blank -%}
          <a href="{{ btn2_url | default: '/pages/about' }}" class="btn btn--ghost btn--lg">{{ btn2_label }}</a>
        {%- endif -%}
      </div>

      <div class="hero__stats">
        {%- if section.settings.stat1_num != blank -%}
          <div class="hero__stat">
            <span class="hero__stat-num">{{ section.settings.stat1_num }}</span>
            <span class="hero__stat-label">{{ section.settings.stat1_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat2_num != blank -%}
          <div class="hero__stat">
            <span class="hero__stat-num">{{ section.settings.stat2_num }}</span>
            <span class="hero__stat-label">{{ section.settings.stat2_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat3_num != blank -%}
          <div class="hero__stat">
            <span class="hero__stat-num">{{ section.settings.stat3_num }}</span>
            <span class="hero__stat-label">{{ section.settings.stat3_label }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="hero__media">
      {%- if section.settings.image != blank -%}
        {{- section.settings.image | image_url: width: 900
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            width: 900,
            height: 1100,
            class: 'hero__img',
            alt: section.settings.image.alt | default: shop.name
        -}}
      {%- else -%}
        <div class="hero__img-placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder' }}</div>
      {%- endif -%}
      <div class="hero__trust-badge">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
        <span>{{ section.settings.trust_text | default: 'Discrétion garantie — emballage neutre' }}</span>
      </div>
    </div>

  </div>
</section>

{% stylesheet %}
.hero {
  background: var(--color-bg, #f7f6f2);
  overflow: hidden;
  padding-block: clamp(3rem, 6vw, 6rem) clamp(2rem, 4vw, 4rem);
}

.hero__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(2rem, 5vw, 4rem);
  align-items: center;
}

@media (min-width: 768px) {
  .hero__inner {
    grid-template-columns: 1fr 1fr;
  }
}

.hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: var(--color-primary, #5b8a8f);
  margin-bottom: 1rem;
}

.hero__title {
  font-size: clamp(2.2rem, 1rem + 4vw, 4.5rem);
  font-weight: 700;
  line-height: 1.1;
  color: var(--color-text, #28251d);
  margin-bottom: 1.25rem;
}

.hero__title em {
  font-style: normal;
  color: var(--color-primary, #5b8a8f);
}

.hero__desc {
  font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
  color: var(--color-text-muted, #7a7974);
  max-width: 48ch;
  line-height: 1.7;
  margin-bottom: 2rem;
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 2.5rem;
}

.btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; font-weight: 600; text-decoration: none; transition: background 200ms ease, transform 120ms ease, box-shadow 200ms ease; cursor: pointer; border: none; }
.btn--lg { padding: 14px 28px; font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1rem); }
.btn--primary { background: var(--color-primary, #5b8a8f); color: #fff; }
.btn--primary:hover { background: var(--color-primary-hover, #3d6b70); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(91,138,143,.3); }
.btn--ghost { background: transparent; color: var(--color-text, #28251d); border: 1.5px solid var(--color-border, #d4d1ca); }
.btn--ghost:hover { border-color: var(--color-primary, #5b8a8f); color: var(--color-primary, #5b8a8f); }

.hero__stats {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--color-divider, #dcd9d5);
}

.hero__stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.hero__stat-num {
  font-size: clamp(1.4rem, 1.2rem + 0.8vw, 2rem);
  font-weight: 800;
  color: var(--color-text, #28251d);
  line-height: 1;
}

.hero__stat-label {
  font-size: 0.78rem;
  color: var(--color-text-muted, #7a7974);
  letter-spacing: .03em;
}

.hero__media {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
}

.hero__img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 16px;
  object-fit: cover;
}

.hero__img-placeholder {
  aspect-ratio: 9/11;
  background: var(--color-surface-offset, #f3f0ec);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero__placeholder { width: 100%; height: 100%; opacity: .3; }

.hero__trust-badge {
  position: absolute;
  bottom: 16px;
  left: 16px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(8px);
  border-radius: 999px;
  padding: 8px 16px;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--color-text, #28251d);
  box-shadow: 0 2px 12px rgba(0,0,0,.1);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Accroche", "default": "Protection & Élégance" },
    { "type": "textarea", "id": "title", "label": "Titre (**italic**)", "default": "La culotte **anti-fuite** qui vous libère" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Discrétion, confort et confiance au quotidien. Nos culottes absorbantes s'adaptent à votre vie." },
    { "type": "text", "id": "btn1_label", "label": "Bouton principal", "default": "Découvrir la gamme" },
    { "type": "url", "id": "btn1_url", "label": "Lien bouton principal" },
    { "type": "text", "id": "btn2_label", "label": "Bouton secondaire", "default": "Choisir mon flux" },
    { "type": "url", "id": "btn2_url", "label": "Lien bouton secondaire" },
    { "type": "image_picker", "id": "image", "label": "Image hero" },
    { "type": "text", "id": "trust_text", "label": "Badge confiance", "default": "Discrétion garantie — emballage neutre" },
    { "type": "header", "content": "Statistiques" },
    { "type": "text", "id": "stat1_num", "label": "Stat 1 — Chiffre", "default": "98%" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 — Label", "default": "Clientes satisfaites" },
    { "type": "text", "id": "stat2_num", "label": "Stat 2 — Chiffre", "default": "2000+" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 — Label", "default": "Avis vérifiés" },
    { "type": "text", "id": "stat3_num", "label": "Stat 3 — Chiffre", "default": "4.9★" },
    { "type": "text", "id": "stat3_label", "label": "Stat 3 — Label", "default": "Note moyenne" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
